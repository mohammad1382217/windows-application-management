<Window x:Class="MilOps.Presentation.Views.SoldierPickerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="انتخاب سرباز"
        Width="420" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="White">
    <StackPanel FlowDirection="RightToLeft">

        <!-- Header -->
        <Border Padding="20,16">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#1C3558" Offset="0"/>
                    <GradientStop Color="#22487A" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <TextBlock x:Name="PromptText" Foreground="White" FontSize="14"
                       FontWeight="SemiBold" TextWrapping="Wrap"/>
        </Border>

        <!-- Picker -->
        <StackPanel Margin="20,18,20,0">
            <ComboBox x:Name="SoldierBox" Padding="10,9" FontSize="13"
                      DisplayMemberPath="DisplayName"
                      TextSearch.TextPath="DisplayName"
                      SelectionChanged="SoldierBox_SelectionChanged"
                      ToolTip="جست‌وجو با تایپ نام خانوادگی امکان‌پذیر است"/>
            <!-- Shown when the caller passed an empty soldier list -->
            <TextBlock x:Name="EmptyHint"
                       Text="⚠ هیچ سرباز فعالی یافت نشد — ابتدا از بخش «سربازان» پرسنل ثبت کنید."
                       Foreground="#B03030" FontSize="12" TextWrapping="Wrap"
                       Margin="0,8,0,0" Visibility="Collapsed"/>
        </StackPanel>

        <!-- Actions -->
        <Grid Margin="20,14,20,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button x:Name="OkButton" Grid.Column="0" Content="تأیید" Style="{StaticResource PrimaryButton}"
                    Padding="0,10" IsDefault="True" IsEnabled="False" Click="Ok_Click"/>
            <Button Grid.Column="2" Content="انصراف" Style="{StaticResource SecondaryButton}"
                    Padding="0,10" IsCancel="True" Click="Cancel_Click"/>
        </Grid>

    </StackPanel>
</Window>
