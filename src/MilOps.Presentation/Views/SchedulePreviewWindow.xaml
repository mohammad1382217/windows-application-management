<Window x:Class="MilOps.Presentation.Views.SchedulePreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="پیش‌نمایش لوح پستی"
        Width="860" Height="600"
        MinWidth="680" MinHeight="440"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="{DynamicResource SurfaceBrush}"
        FlowDirection="RightToLeft">

    <Border ClipToBounds="True">
        <DockPanel>

            <!-- Header -->
            <Border DockPanel.Dock="Top" Padding="24,18">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#1A3A5C" Offset="0"/>
                        <GradientStop Color="#215080" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <DockPanel>
                    <Border DockPanel.Dock="Right" Width="48" Height="48" CornerRadius="24"
                            Background="#22FFFFFF" VerticalAlignment="Center">
                        <TextBlock Text="📋" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center" Margin="0,0,14,0">
                        <TextBlock Text="لوح پستی — برنامه نگهبانی روزانه" Foreground="White"
                                   FontSize="17" FontWeight="Bold" TextAlignment="Right"/>
                        <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                            <TextBlock Text="تاریخ: " Foreground="#90B8D8" FontSize="12"/>
                            <TextBlock Text="{Binding Date, Converter={StaticResource JalaliDateConverter}}"
                                       Foreground="White" FontSize="12" FontWeight="SemiBold"/>
                            <TextBlock Text="  ·  تعداد نفرات: " Foreground="#90B8D8" FontSize="12"/>
                            <TextBlock Text="{Binding Assignments.Count, Converter={StaticResource PersianDigitsConverter}}"
                                       Foreground="White" FontSize="12" FontWeight="SemiBold"/>
                        </StackPanel>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Bottom action bar -->
            <Border DockPanel.Dock="Bottom" Background="#F4F7FA"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0"
                    Padding="24,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="⬇ ذخیره PDF" Style="{StaticResource PrimaryButton}"
                            Click="Pdf_Click" Margin="0,0,8,0"
                            ToolTip="ذخیره لوح پستی به‌صورت فایل PDF — بدون نیاز به چاپگر"/>
                    <Button Grid.Column="1" Content="🖨 چاپ" Style="{StaticResource SecondaryButton}"
                            Click="Print_Click"
                            ToolTip="چاپ مستقیم با چاپگر متصل"/>
                    <Button Grid.Column="3" Content="بستن" Style="{StaticResource SecondaryButton}"
                            IsCancel="True" Click="Close_Click"/>
                </Grid>
            </Border>

            <!-- Remarks (only when present) -->
            <Border DockPanel.Dock="Top" Background="#FFFDF3" Padding="24,10"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1"
                    Visibility="{Binding Remarks, Converter={StaticResource NullToVisibilityConverter}}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="ملاحظات: " FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding Remarks}" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- Board -->
            <DataGrid FlowDirection="RightToLeft" Background="White"
                      ItemsSource="{Binding Assignments}"
                      AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="سرباز"       Binding="{Binding SoldierDisplay}" Width="200"/>
                    <DataGridTextColumn Header="پست"          Binding="{Binding Post,  Converter={StaticResource EnumDescriptionConverter}}"  Width="180"/>
                    <DataGridTextColumn Header="شیفت"         Binding="{Binding Shift, Converter={StaticResource EnumDescriptionConverter}}"  Width="110"/>
                    <DataGridTextColumn Header="ساعت شروع"   Binding="{Binding ShiftStart, StringFormat='{}{0:HH\\:mm}'}" Width="110"/>
                    <DataGridTextColumn Header="ساعت پایان"  Binding="{Binding ShiftEnd,   StringFormat='{}{0:HH\\:mm}'}" Width="110"/>
                    <DataGridTextColumn Header="ملاحظات"      Binding="{Binding Note}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>

        </DockPanel>
    </Border>
</Window>
