<Window x:Class="MilOps.Presentation.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:MilOps.Presentation.ViewModels"
        xmlns:v="clr-namespace:MilOps.Presentation.Views"
        Title="سنگر" Height="740" Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource SurfaceBrush}">
    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:SoldiersViewModel}">
            <v:SoldiersView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SchedulesViewModel}">
            <v:SchedulesView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:WeaponsViewModel}">
            <v:WeaponsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:LeavesViewModel}">
            <v:LeavesView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:TokensViewModel}">
            <v:TokensView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:UsersViewModel}">
            <v:UsersView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:AuditViewModel}">
            <v:AuditView/>
        </DataTemplate>
    </Window.Resources>

    <DockPanel>
        <!-- Slim top bar: module title + user info + logout -->
        <Border DockPanel.Dock="Top" Background="White" Height="52"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
            <Border.Effect>
                <DropShadowEffect Color="#14000000" BlurRadius="8" ShadowDepth="1" Direction="270"/>
            </Border.Effect>
            <DockPanel Margin="20,0">
                <!-- Physical RIGHT: module title -->
                <TextBlock Text="{Binding CurrentTitle}" DockPanel.Dock="Right"
                           FontSize="15" FontWeight="Bold"
                           Foreground="{DynamicResource PrimaryBrush}"
                           VerticalAlignment="Center"/>
                <!-- Physical LEFT: logout + user banner -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="خروج" Command="{Binding LogoutCommand}"
                            Style="{StaticResource DangerButton}" Padding="16,6" Margin="0,0,12,0"/>
                    <TextBlock Text="{Binding UserBanner}"
                               Foreground="{DynamicResource MutedBrush}" FontSize="12"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Sidebar on the right (Persian RTL: nav belongs on the right edge) -->
        <Border DockPanel.Dock="Right" Width="220" Background="#1C3558">
            <DockPanel>
                <!-- Brand logo -->
                <Border DockPanel.Dock="Top" Padding="16,28,16,22"
                        BorderBrush="#28456C" BorderThickness="0,0,0,1">
                    <StackPanel HorizontalAlignment="Center">
                        <Viewbox Width="62" Height="62" HorizontalAlignment="Center">
                            <Viewbox.Effect>
                                <DropShadowEffect Color="#000000" Opacity="0.4" BlurRadius="8" ShadowDepth="2"/>
                            </Viewbox.Effect>
                            <Canvas Width="100" Height="100">
                                <Ellipse Width="100" Height="100" Fill="#0A1520"/>
                                <Ellipse Canvas.Left="4"  Canvas.Top="4"  Width="92" Height="92"
                                         Stroke="#C9A227" StrokeThickness="2.5" Fill="Transparent"/>
                                <Ellipse Canvas.Left="13" Canvas.Top="13" Width="74" Height="74"
                                         Stroke="#C9A227" StrokeThickness="1"   Fill="Transparent"/>
                                <Path Fill="White"
                                      Data="M 50,12 L 59,37 L 86,38 L 65,55 L 72,81 L 50,66 L 28,81 L 35,55 L 14,38 L 41,37 Z"/>
                                <Ellipse Canvas.Left="45" Canvas.Top="45" Width="10" Height="10"
                                         Fill="#C9A227"/>
                            </Canvas>
                        </Viewbox>
                        <TextBlock Text="سنگر" Foreground="White" FontSize="20" FontWeight="Bold"
                                   HorizontalAlignment="Center" Margin="0,8,0,0"/>
                        <TextBlock Text="سامانهٔ مدیریت یگان نظامی" Foreground="#5D86B0" FontSize="11"
                                   HorizontalAlignment="Center" Margin="0,5,0,0"
                                   TextWrapping="Wrap" TextAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Version footer -->
                <Border DockPanel.Dock="Bottom" Padding="16,12"
                        BorderBrush="#243E5E" BorderThickness="0,1,0,0">
                    <TextBlock Text="نسخه ۱.۰" Foreground="#344F6E" FontSize="11"
                               HorizontalAlignment="Center"/>
                </Border>

                <!-- Nav items -->
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="8,18,8,8">
                        <TextBlock Text="بخش‌های سامانه" Foreground="#344F6E" FontSize="10"
                                   FontWeight="Bold" Margin="16,0,0,10"/>
                        <Button Content="👥  سربازان" Style="{StaticResource NavItem}"
                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Right"
                                Command="{Binding ShowSoldiersCommand}"
                                Visibility="{Binding CanManageSoldiers, Converter={StaticResource BoolToVisConverter}}"/>
                        <Button Content="📅  برنامه نگهبانی" Style="{StaticResource NavItem}"
                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Right"
                                Command="{Binding ShowSchedulesCommand}"
                                Visibility="{Binding CanManageSchedules, Converter={StaticResource BoolToVisConverter}}"/>
                        <Button Content="🔫  تسلیحات" Style="{StaticResource NavItem}"
                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Right"
                                Command="{Binding ShowWeaponsCommand}"
                                Visibility="{Binding CanManageWeapons, Converter={StaticResource BoolToVisConverter}}"/>
                        <Button Content="🏖  مرخصی‌ها" Style="{StaticResource NavItem}"
                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Right"
                                Command="{Binding ShowLeavesCommand}"
                                Visibility="{Binding CanManageLeaves, Converter={StaticResource BoolToVisConverter}}"/>
                        <Button Content="🔑  توکن‌ها" Style="{StaticResource NavItem}"
                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Right"
                                Command="{Binding ShowTokensCommand}"
                                Visibility="{Binding CanManageTokens, Converter={StaticResource BoolToVisConverter}}"/>
                        <Button Content="⚙  کاربران" Style="{StaticResource NavItem}"
                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Right"
                                Command="{Binding ShowUsersCommand}"
                                Visibility="{Binding CanManageUsers, Converter={StaticResource BoolToVisConverter}}"/>
                        <Button Content="📜  گزارش حسابرسی" Style="{StaticResource NavItem}"
                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Right"
                                Command="{Binding ShowAuditCommand}"
                                Visibility="{Binding CanViewAudit, Converter={StaticResource BoolToVisConverter}}"/>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- Content host -->
        <Grid>
            <ContentControl Content="{Binding Current}"/>

            <!-- Welcome dashboard -->
            <Grid Visibility="{Binding Current, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=inverse}"
                  FlowDirection="RightToLeft">

                <!-- Full-area subtle background -->
                <Border>
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#EEF2F6" Offset="0"/>
                            <GradientStop Color="#E0EAF4" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>

                <!-- Centered welcome card -->
                <Border MaxWidth="580" MaxHeight="440"
                        VerticalAlignment="Center" HorizontalAlignment="Center"
                        CornerRadius="16" ClipToBounds="True"
                        BorderBrush="#D0DCE8" BorderThickness="1"
                        Margin="40">
                    <Border.Effect>
                        <DropShadowEffect Color="#18000000" BlurRadius="24" ShadowDepth="4" Direction="270"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="180"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Gradient header -->
                        <Border Grid.Row="0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#1C3558" Offset="0"/>
                                    <GradientStop Color="#2E6EA6" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Viewbox Width="96" Height="96" HorizontalAlignment="Center">
                                    <Viewbox.Effect>
                                        <DropShadowEffect Color="#000000" Opacity="0.35" BlurRadius="12" ShadowDepth="3"/>
                                    </Viewbox.Effect>
                                    <Canvas Width="100" Height="100">
                                        <Ellipse Width="100" Height="100" Fill="#0F1E30"/>
                                        <Ellipse Canvas.Left="4"  Canvas.Top="4"  Width="92" Height="92"
                                                 Stroke="#C9A227" StrokeThickness="2.5" Fill="Transparent"/>
                                        <Ellipse Canvas.Left="13" Canvas.Top="13" Width="74" Height="74"
                                                 Stroke="#C9A227" StrokeThickness="1"   Fill="Transparent"/>
                                        <Path Fill="White"
                                              Data="M 50,12 L 59,37 L 86,38 L 65,55 L 72,81 L 50,66 L 28,81 L 35,55 L 14,38 L 41,37 Z"/>
                                        <Ellipse Canvas.Left="45" Canvas.Top="45" Width="10" Height="10"
                                                 Fill="#C9A227"/>
                                    </Canvas>
                                </Viewbox>
                                <TextBlock Text="سنگر" Foreground="White" FontSize="26"
                                           FontWeight="Bold" HorizontalAlignment="Center"
                                           Margin="0,10,0,0"/>
                                <TextBlock Text="سامانهٔ مدیریت یگان نظامی" Foreground="#9DC4E0"
                                           FontSize="12" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Body -->
                        <Border Grid.Row="1" Background="White" Padding="40,28">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="{Binding UserBanner}"
                                           FontSize="16" FontWeight="Bold"
                                           Foreground="{DynamicResource PrimaryBrush}"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="برای شروع کار، یک بخش را از منوی سمت راست انتخاب کنید."
                                           FontSize="13" Foreground="{DynamicResource MutedBrush}"
                                           HorizontalAlignment="Center" TextWrapping="Wrap"
                                           TextAlignment="Center" Margin="0,10,0,0" MaxWidth="380"/>

                                <!-- Feature chips -->
                                <WrapPanel HorizontalAlignment="Center" Margin="0,22,0,0">
                                    <Border Background="#F0F5FA" CornerRadius="20" Padding="14,7" Margin="5,4">
                                        <TextBlock Text="👥 سربازان" Foreground="{DynamicResource PrimaryBrush}" FontSize="12"/>
                                    </Border>
                                    <Border Background="#FFF5F0" CornerRadius="20" Padding="14,7" Margin="5,4">
                                        <TextBlock Text="🔫 تسلیحات" Foreground="#9B2335" FontSize="12"/>
                                    </Border>
                                    <Border Background="#F0FAF3" CornerRadius="20" Padding="14,7" Margin="5,4">
                                        <TextBlock Text="🏖 مرخصی" Foreground="#1E8449" FontSize="12"/>
                                    </Border>
                                    <Border Background="#F5F0FA" CornerRadius="20" Padding="14,7" Margin="5,4">
                                        <TextBlock Text="🔑 توکن" Foreground="#6C3AAA" FontSize="12"/>
                                    </Border>
                                    <Border Background="#F0F5FA" CornerRadius="20" Padding="14,7" Margin="5,4">
                                        <TextBlock Text="📅 نگهبانی" Foreground="{DynamicResource PrimaryBrush}" FontSize="12"/>
                                    </Border>
                                </WrapPanel>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </DockPanel>
</Window>
