<Window x:Class="MilOps.Presentation.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:MilOps.Presentation.ViewModels"
        xmlns:v="clr-namespace:MilOps.Presentation.Views"
        Title="سنگر" Height="740" Width="1200"
        MinWidth="960" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource SurfaceBrush}">
    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:SoldiersViewModel}">
            <v:SoldiersView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:AttendanceViewModel}">
            <v:AttendanceView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
            <v:SettingsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SchedulesViewModel}">
            <v:SchedulesView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:WeaponsViewModel}">
            <v:WeaponsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:LeavesViewModel}">
            <v:LeavesView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:TokensViewModel}">
            <v:TokensView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:UsersViewModel}">
            <v:UsersView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:AuditViewModel}">
            <v:AuditView/>
        </DataTemplate>
    </Window.Resources>

    <DockPanel>
        <!-- Slim top bar: module title + user info + logout -->
        <Border DockPanel.Dock="Top" Background="White" Height="52"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
            <Border.Effect>
                <DropShadowEffect Color="#14000000" BlurRadius="8" ShadowDepth="1" Direction="270"/>
            </Border.Effect>
            <DockPanel Margin="20,0">
                <!-- Physical RIGHT: module title -->
                <TextBlock Text="{Binding CurrentTitle}" DockPanel.Dock="Right"
                           FontSize="15" FontWeight="Bold"
                           Foreground="{DynamicResource PrimaryBrush}"
                           VerticalAlignment="Center"/>
                <!-- Physical LEFT: logout + user banner -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="خروج" Command="{Binding LogoutCommand}"
                            IsEnabled="{Binding IsNotBusy}"
                            Style="{StaticResource DangerButton}" MinHeight="32" Padding="16,0" Margin="0,0,12,0"/>
                    <TextBlock Text="{Binding UserBanner}"
                               Foreground="{DynamicResource MutedBrush}" FontSize="12"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Sidebar (Persian RTL: nav belongs on the right edge) -->
        <Border DockPanel.Dock="Right" Width="220" Background="#1C3558">
            <DockPanel>
                <!-- Brand logo -->
                <Border DockPanel.Dock="Top" Padding="16,28,16,22"
                        BorderBrush="#28456C" BorderThickness="0,0,0,1">
                    <StackPanel HorizontalAlignment="Center">
                        <Viewbox Width="62" Height="62" HorizontalAlignment="Center">
                            <Viewbox.Effect>
                                <DropShadowEffect Color="#000000" Opacity="0.4" BlurRadius="8" ShadowDepth="2"/>
                            </Viewbox.Effect>
                            <Canvas Width="100" Height="100">
                                <Ellipse Width="100" Height="100" Fill="#0A1520"/>
                                <Ellipse Canvas.Left="4"  Canvas.Top="4"  Width="92" Height="92"
                                         Stroke="#C9A227" StrokeThickness="2.5" Fill="Transparent"/>
                                <Ellipse Canvas.Left="13" Canvas.Top="13" Width="74" Height="74"
                                         Stroke="#C9A227" StrokeThickness="1"   Fill="Transparent"/>
                                <Path Fill="White"
                                      Data="M 50,12 L 59,37 L 86,38 L 65,55 L 72,81 L 50,66 L 28,81 L 35,55 L 14,38 L 41,37 Z"/>
                                <Ellipse Canvas.Left="45" Canvas.Top="45" Width="10" Height="10"
                                         Fill="#C9A227"/>
                            </Canvas>
                        </Viewbox>
                        <TextBlock Text="سنگر" Foreground="White" FontSize="20" FontWeight="Bold"
                                   HorizontalAlignment="Center" Margin="0,8,0,0"/>
                        <TextBlock Text="سامانهٔ مدیریت یگان نظامی" Foreground="#5D86B0" FontSize="11"
                                   HorizontalAlignment="Center" Margin="0,5,0,0"
                                   TextWrapping="Wrap" TextAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Version footer -->
                <Border DockPanel.Dock="Bottom" Padding="16,12"
                        BorderBrush="#243E5E" BorderThickness="0,1,0,0">
                    <TextBlock Text="نسخه ۱.۰" Foreground="#344F6E" FontSize="11"
                               HorizontalAlignment="Center"/>
                </Border>

                <!-- Nav items — each uses inline style with DataTrigger for active state -->
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="8,18,8,8">
                        <TextBlock Text="بخش‌های سامانه" Foreground="#344F6E" FontSize="10"
                                   FontWeight="Bold" Margin="16,0,0,10"/>

                        <Button HorizontalAlignment="Stretch" HorizontalContentAlignment="Right"
                                Content="👥  سربازان" ToolTip="سربازان"
                                Command="{Binding ShowSoldiersCommand}"
                                Visibility="{Binding CanManageSoldiers, Converter={StaticResource BoolToVisConverter}}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource NavItem}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSoldiersActive}" Value="True">
                                            <Setter Property="FontWeight" Value="Bold"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button HorizontalAlignment="Stretch" HorizontalContentAlignment="Right"
                                Content="📝  آمار و حضور" ToolTip="آمار و حضور و غیاب"
                                Command="{Binding ShowAttendanceCommand}"
                                Visibility="{Binding CanManageAttendance, Converter={StaticResource BoolToVisConverter}}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource NavItem}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsAttendanceActive}" Value="True">
                                            <Setter Property="FontWeight" Value="Bold"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button HorizontalAlignment="Stretch" HorizontalContentAlignment="Right"
                                Content="📅  برنامه نگهبانی" ToolTip="برنامه نگهبانی"
                                Command="{Binding ShowSchedulesCommand}"
                                Visibility="{Binding CanManageSchedules, Converter={StaticResource BoolToVisConverter}}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource NavItem}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSchedulesActive}" Value="True">
                                            <Setter Property="FontWeight" Value="Bold"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button HorizontalAlignment="Stretch" HorizontalContentAlignment="Right"
                                Content="🔫  تسلیحات" ToolTip="تسلیحات"
                                Command="{Binding ShowWeaponsCommand}"
                                Visibility="{Binding CanManageWeapons, Converter={StaticResource BoolToVisConverter}}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource NavItem}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsWeaponsActive}" Value="True">
                                            <Setter Property="FontWeight" Value="Bold"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button HorizontalAlignment="Stretch" HorizontalContentAlignment="Right"
                                Content="🏖  مرخصی‌ها" ToolTip="مرخصی‌ها"
                                Command="{Binding ShowLeavesCommand}"
                                Visibility="{Binding CanManageLeaves, Converter={StaticResource BoolToVisConverter}}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource NavItem}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsLeavesActive}" Value="True">
                                            <Setter Property="FontWeight" Value="Bold"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button HorizontalAlignment="Stretch" HorizontalContentAlignment="Right"
                                Content="🔑  توکن‌ها" ToolTip="توکن‌های فرمانده"
                                Command="{Binding ShowTokensCommand}"
                                Visibility="{Binding CanManageTokens, Converter={StaticResource BoolToVisConverter}}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource NavItem}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsTokensActive}" Value="True">
                                            <Setter Property="FontWeight" Value="Bold"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button HorizontalAlignment="Stretch" HorizontalContentAlignment="Right"
                                Content="⚙  کاربران" ToolTip="مدیریت کاربران"
                                Command="{Binding ShowUsersCommand}"
                                Visibility="{Binding CanManageUsers, Converter={StaticResource BoolToVisConverter}}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource NavItem}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsUsersActive}" Value="True">
                                            <Setter Property="FontWeight" Value="Bold"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button HorizontalAlignment="Stretch" HorizontalContentAlignment="Right"
                                Content="📜  گزارش حسابرسی" ToolTip="گزارش حسابرسی"
                                Command="{Binding ShowAuditCommand}"
                                Visibility="{Binding CanViewAudit, Converter={StaticResource BoolToVisConverter}}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource NavItem}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsAuditActive}" Value="True">
                                            <Setter Property="FontWeight" Value="Bold"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button HorizontalAlignment="Stretch" HorizontalContentAlignment="Right"
                                Content="🛠  تنظیمات" ToolTip="تنظیمات"
                                Command="{Binding ShowSettingsCommand}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource NavItem}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSettingsActive}" Value="True">
                                            <Setter Property="FontWeight" Value="Bold"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- Content host — directly shows the current feature view -->
        <Grid>
            <ContentControl Content="{Binding Current}"/>

            <!-- Busy overlay: without this, switching sections while the newly
                 opened view is still loading its data looked frozen (no feedback). -->
            <Border Background="#66FFFFFF"
                    Visibility="{Binding Current.IsBusy, Converter={StaticResource BoolToVisConverter}, FallbackValue=Collapsed}">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <ProgressBar IsIndeterminate="True" Width="160" Height="4"/>
                    <TextBlock Text="در حال بارگذاری…" Foreground="{DynamicResource MutedBrush}"
                               FontSize="12" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>
        </Grid>
    </DockPanel>
</Window>
