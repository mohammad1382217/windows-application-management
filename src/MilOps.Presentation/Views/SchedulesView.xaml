<UserControl x:Class="MilOps.Presentation.Views.SchedulesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:v="clr-namespace:MilOps.Presentation.Views"
             FlowDirection="RightToLeft"
             Loaded="SchedulesView_Loaded">
    <Border Margin="16" CornerRadius="12" ClipToBounds="True"
            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
        <DockPanel>

            <!-- Header -->
            <Border DockPanel.Dock="Top" Padding="22,18">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#1A3A5C" Offset="0"/>
                        <GradientStop Color="#215080" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <DockPanel>
                    <Border DockPanel.Dock="Right" Width="52" Height="52" CornerRadius="26"
                            Background="#22FFFFFF" VerticalAlignment="Center">
                        <TextBlock Text="📅" FontSize="26" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center" Margin="0,0,16,0">
                        <TextBlock Text="برنامه نگهبانی" Foreground="White" FontSize="20" FontWeight="Bold"/>
                        <TextBlock Text="مدیریت شیفت‌ها و پست‌های نگهبانی" Foreground="#90B8D8" FontSize="12" Margin="0,4,0,0"/>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Toolbar -->
            <Border DockPanel.Dock="Top" Background="White" Padding="14,12"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <Button Content="＋ برنامه جدید" Style="{StaticResource PrimaryButton}"
                                Command="{Binding CreateCommand}" Padding="14,7" Margin="0,0,8,0"/>
                        <Button Content="✓ تأیید برنامه" Style="{StaticResource AccentButton}"
                                Command="{Binding ApproveCommand}" Padding="14,7" Margin="0,0,8,0"/>
                        <Button Content="⬇ PDF" Style="{StaticResource SecondaryButton}"
                                Command="{Binding ExportPdfCommand}" Padding="14,7" Margin="0,0,8,0"
                                ToolTip="ذخیره لوح پستی به‌صورت فایل PDF — بدون نیاز به چاپگر"/>
                        <Button Content="🖨 چاپ برنامه" Style="{StaticResource SecondaryButton}"
                                Command="{Binding PrintCommand}" Padding="14,7"
                                ToolTip="چاپ مستقیم با چاپگر متصل"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="تاریخ:" Style="{StaticResource FieldLabel}" Margin="0,0,8,0"/>
                        <v:JalaliDatePicker SelectedDate="{Binding Date}" Width="150"/>
                        <Button Content="بارگذاری" Style="{StaticResource PrimaryButton}"
                                Command="{Binding LoadCommand}" Padding="14,7" Margin="8,0,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Error -->
            <TextBlock DockPanel.Dock="Bottom" Text="{Binding ErrorMessage}"
                       Foreground="{DynamicResource DangerBrush}" Margin="14,6,14,0" TextWrapping="Wrap"
                       Visibility="{Binding ErrorMessage, Converter={StaticResource NullToCollapsedConverter}}"/>

            <!-- Master (recent schedules) / Detail (board of the clicked schedule) -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="260"/>
                    <ColumnDefinition Width="1"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Recent schedules list -->
                <DockPanel Grid.Column="0">
                    <Border DockPanel.Dock="Top" Background="#F8FAFC" Padding="12,8"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                        <TextBlock Text="برنامه‌های اخیر — برای مشاهده لوح کلیک کنید"
                                   Style="{StaticResource FieldLabel}" TextWrapping="Wrap"/>
                    </Border>
                    <DataGrid FlowDirection="RightToLeft"
                              ItemsSource="{Binding Schedules}" SelectedItem="{Binding SelectedSchedule}"
                              AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False"
                              HeadersVisibility="Column" GridLinesVisibility="Horizontal">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="تاریخ" Width="110"
                                Binding="{Binding Date, Converter={StaticResource JalaliDateConverter}}"/>
                            <DataGridTextColumn Header="وضعیت" Width="90"
                                Binding="{Binding Status, Converter={StaticResource EnumDescriptionConverter}}"/>
                            <DataGridTextColumn Header="نفرات" Width="55"
                                Binding="{Binding AssignmentCount, Converter={StaticResource PersianDigitsConverter}}"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>

                <Border Grid.Column="1" Background="{DynamicResource BorderBrush}"/>

                <!-- Board (لوح) of the selected/loaded schedule -->
                <DockPanel Grid.Column="2">
                    <Border DockPanel.Dock="Top" Background="#F0F4F8" Padding="16,10"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1"
                            Visibility="{Binding Current, Converter={StaticResource NullToVisibilityConverter}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{StaticResource FieldLabel}" Text="وضعیت:"/>
                            <TextBlock Text="{Binding Current.Status, Converter={StaticResource EnumDescriptionConverter}}" FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}" Margin="6,0,20,0"/>
                            <TextBlock Style="{StaticResource FieldLabel}" Text="تاریخ:"/>
                            <TextBlock Text="{Binding Current.Date, Converter={StaticResource JalaliDateConverter}}" Margin="6,0,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Empty placeholder when nothing is opened yet -->
                    <TextBlock DockPanel.Dock="Top"
                               Text="از فهرست سمت راست یک برنامه انتخاب کنید، یا یک تاریخ را از بالا بارگذاری نمایید."
                               Foreground="{DynamicResource MutedBrush}" FontSize="13"
                               HorizontalAlignment="Center" Margin="0,40,0,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Current}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <DataGrid FlowDirection="RightToLeft"
                              ItemsSource="{Binding Assignments}" AutoGenerateColumns="False"
                              IsReadOnly="True" CanUserAddRows="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="سرباز" Binding="{Binding SoldierDisplay}" Width="180"/>
                            <DataGridTextColumn Header="پست"          Binding="{Binding Post,  Converter={StaticResource EnumDescriptionConverter}}"   Width="180"/>
                            <DataGridTextColumn Header="شیفت"         Binding="{Binding Shift, Converter={StaticResource EnumDescriptionConverter}}"   Width="100"/>
                            <DataGridTextColumn Header="ساعت شروع"   Binding="{Binding ShiftStart, StringFormat='{}{0:HH\\:mm}'}"  Width="110"/>
                            <DataGridTextColumn Header="ساعت پایان"  Binding="{Binding ShiftEnd,   StringFormat='{}{0:HH\\:mm}'}"  Width="110"/>
                            <DataGridTextColumn Header="ملاحظات"      Binding="{Binding Note}"       Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Grid>

        </DockPanel>
    </Border>
</UserControl>
