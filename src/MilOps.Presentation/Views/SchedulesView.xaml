<UserControl x:Class="MilOps.Presentation.Views.SchedulesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FlowDirection="RightToLeft"
             Loaded="SchedulesView_Loaded">
    <Border Margin="16" CornerRadius="12" ClipToBounds="True"
            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
        <DockPanel>

            <!-- Header -->
            <Border DockPanel.Dock="Top" Padding="22,18">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#1A3A5C" Offset="0"/>
                        <GradientStop Color="#215080" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <DockPanel>
                    <Border DockPanel.Dock="Right" Width="52" Height="52" CornerRadius="26"
                            Background="#22FFFFFF" VerticalAlignment="Center">
                        <TextBlock Text="📅" FontSize="26" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center" Margin="0,0,16,0">
                        <TextBlock Text="برنامه نگهبانی" Foreground="White" FontSize="20" FontWeight="Bold"/>
                        <TextBlock Text="مدیریت شیفت‌ها و پست‌های نگهبانی" Foreground="#90B8D8" FontSize="12" Margin="0,4,0,0"/>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Toolbar -->
            <Border DockPanel.Dock="Top" Background="White" Padding="14,12"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <Button Content="＋ برنامه جدید" Style="{StaticResource AccentButton}"
                                Command="{Binding CreateCommand}" Margin="0,0,8,0"/>
                        <Button Content="⟳ بازخوانی" Style="{StaticResource SecondaryButton}"
                                Command="{Binding LoadSchedulesCommand}"/>
                    </StackPanel>

                    <TextBlock Grid.Column="2" Style="{StaticResource Caption}" VerticalAlignment="Center"
                               Text="برای مشاهده لوح، روی هر برنامه دوبار کلیک کنید"/>
                </Grid>
            </Border>

            <!-- Error -->
            <TextBlock DockPanel.Dock="Bottom" Text="{Binding ErrorMessage}"
                       Foreground="{DynamicResource DangerBrush}" Margin="14,6,14,0" TextWrapping="Wrap"
                       Visibility="{Binding ErrorMessage, Converter={StaticResource NullToCollapsedConverter}}"/>

            <!-- Full-width schedule list; each row carries its own preview/edit actions -->
            <Grid>
                <DataGrid FlowDirection="RightToLeft" RowHeight="44"
                          ItemsSource="{Binding Schedules}" SelectedItem="{Binding SelectedSchedule}"
                          AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False"
                          MouseDoubleClick="DataGrid_MouseDoubleClick">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="تاریخ" Width="160"
                            Binding="{Binding Date, Converter={StaticResource JalaliDateConverter}}"/>
                        <DataGridTextColumn Header="تعداد نفرات" Width="120"
                            Binding="{Binding AssignmentCount, Converter={StaticResource PersianDigitsConverter}}"/>
                        <DataGridTemplateColumn Header="عملیات" Width="240">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                                                VerticalAlignment="Center">
                                        <Button Content="👁 پیش‌نمایش" Style="{StaticResource SecondaryButton}"
                                                MinHeight="0" Height="30" Padding="12,0" FontSize="12"
                                                Command="{Binding DataContext.PreviewCommand,
                                                    RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"
                                                ToolTip="نمایش لوح پستی با امکان چاپ و PDF"/>
                                        <Button Content="✎ ویرایش" Style="{StaticResource PrimaryButton}"
                                                MinHeight="0" Height="30" Padding="12,0" FontSize="12" Margin="8,0,0,0"
                                                Command="{Binding DataContext.EditCommand,
                                                    RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"
                                                ToolTip="ویرایش ردیف‌های این برنامه"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <!-- filler so the action column doesn't stretch -->
                        <DataGridTextColumn Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Empty state -->
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,60,0,0">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Schedules.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Text="📅" FontSize="40" HorizontalAlignment="Center" Opacity="0.5"/>
                    <TextBlock Text="هنوز برنامه‌ای ثبت نشده است — با «برنامه جدید» اولین لوح پستی را بسازید."
                               Foreground="{DynamicResource MutedBrush}" FontSize="13" Margin="0,10,0,0"/>
                </StackPanel>

                <!-- Busy overlay -->
                <Border Background="#66FFFFFF"
                        Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisConverter}}">
                    <ProgressBar IsIndeterminate="True" Width="160" Height="4"
                                 VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </Border>
            </Grid>

        </DockPanel>
    </Border>
</UserControl>
