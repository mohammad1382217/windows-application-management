<UserControl x:Class="MilOps.Presentation.Views.SchedulesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:v="clr-namespace:MilOps.Presentation.Views"
             FlowDirection="RightToLeft"
             Loaded="SchedulesView_Loaded">
    <Border Margin="16" CornerRadius="12" ClipToBounds="True"
            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
        <DockPanel>

            <!-- Header -->
            <Border DockPanel.Dock="Top" Padding="22,18">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#1A3A5C" Offset="0"/>
                        <GradientStop Color="#215080" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <DockPanel>
                    <Border DockPanel.Dock="Right" Width="52" Height="52" CornerRadius="26"
                            Background="#22FFFFFF" VerticalAlignment="Center">
                        <TextBlock Text="📅" FontSize="26" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center" Margin="0,0,16,0">
                        <TextBlock Text="برنامه نگهبانی" Foreground="White" FontSize="20" FontWeight="Bold"/>
                        <TextBlock Text="مدیریت شیفت‌ها و پست‌های نگهبانی" Foreground="#90B8D8" FontSize="12" Margin="0,4,0,0"/>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Toolbar -->
            <Border DockPanel.Dock="Top" Background="White" Padding="14,12"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <Button Content="＋ برنامه جدید" Style="{StaticResource PrimaryButton}"
                                Command="{Binding CreateCommand}" Padding="14,7" Margin="0,0,8,0"/>
                        <Button Content="✓ تأیید برنامه" Style="{StaticResource AccentButton}"
                                Command="{Binding ApproveCommand}" Padding="14,7" Margin="0,0,8,0"/>
                        <Button Content="🖨 چاپ برنامه" Style="{StaticResource SecondaryButton}"
                                Command="{Binding PrintCommand}" Padding="14,7"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="تاریخ:" Style="{StaticResource FieldLabel}" Margin="0,0,8,0"/>
                        <v:JalaliDatePicker SelectedDate="{Binding Date}" Width="150"/>
                        <Button Content="بارگذاری" Style="{StaticResource PrimaryButton}"
                                Command="{Binding LoadCommand}" Padding="14,7" Margin="8,0,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Status bar -->
            <Border DockPanel.Dock="Top" Background="#F0F4F8" Padding="16,10"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1"
                    Visibility="{Binding Current, Converter={StaticResource NullToVisibilityConverter}}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Style="{StaticResource FieldLabel}" Text="وضعیت:"/>
                    <TextBlock Text="{Binding Current.Status}" FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}" Margin="6,0,20,0"/>
                    <TextBlock Style="{StaticResource FieldLabel}" Text="تاریخ:"/>
                    <TextBlock Text="{Binding Current.Date, Converter={StaticResource JalaliDateConverter}}" Margin="6,0,0,0"/>
                </StackPanel>
            </Border>

            <!-- Error -->
            <TextBlock DockPanel.Dock="Bottom" Text="{Binding ErrorMessage}"
                       Foreground="{DynamicResource DangerBrush}" Margin="14,6,14,0" TextWrapping="Wrap"
                       Visibility="{Binding ErrorMessage, Converter={StaticResource NullToCollapsedConverter}}"/>

            <!-- Data -->
            <DataGrid FlowDirection="RightToLeft"
                      ItemsSource="{Binding Assignments}" AutoGenerateColumns="False"
                      IsReadOnly="True" CanUserAddRows="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="شناسه سرباز" Binding="{Binding SoldierId}"  Width="110"/>
                    <DataGridTextColumn Header="پست"          Binding="{Binding Post,  Converter={StaticResource EnumDescriptionConverter}}"   Width="180"/>
                    <DataGridTextColumn Header="شیفت"         Binding="{Binding Shift, Converter={StaticResource EnumDescriptionConverter}}"   Width="100"/>
                    <DataGridTextColumn Header="ساعت شروع"   Binding="{Binding ShiftStart}"  Width="130"/>
                    <DataGridTextColumn Header="ملاحظات"      Binding="{Binding Note}"       Width="*"/>
                </DataGrid.Columns>
            </DataGrid>

        </DockPanel>
    </Border>
</UserControl>
