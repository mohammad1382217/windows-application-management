<UserControl x:Class="MilOps.Presentation.Views.SchedulesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Loaded="SchedulesView_Loaded">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
            <TextBlock Text="Date:" Style="{StaticResource FieldLabel}"/>
            <DatePicker SelectedDate="{Binding Date}" Margin="0,0,8,0"/>
            <Button Content="Load" Style="{StaticResource PrimaryButton}" Command="{Binding LoadCommand}" Margin="0,0,8,0"/>
            <Button Content="✓ Approve" Style="{StaticResource PrimaryButton}" Command="{Binding ApproveCommand}" Margin="0,0,8,0"/>
            <Button Content="🖨 Print Schedule" Style="{StaticResource PrimaryButton}" Command="{Binding PrintCommand}"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="Status: " Style="{StaticResource FieldLabel}"/>
            <TextBlock Text="{Binding Current.Status}" FontWeight="Bold"/>
            <TextBlock Text="{Binding Current.Date, StringFormat='  ·  Date: {0:yyyy-MM-dd}'}" Margin="16,0,0,0"/>
        </StackPanel>

        <Border Grid.Row="2" Background="White" BorderBrush="#FFE0E0E0" BorderThickness="1">
            <DataGrid ItemsSource="{Binding Assignments}" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Soldier ID" Binding="{Binding SoldierId}" Width="100"/>
                    <DataGridTextColumn Header="Post" Binding="{Binding Post}" Width="160"/>
                    <DataGridTextColumn Header="Shift" Binding="{Binding Shift}" Width="100"/>
                    <DataGridTextColumn Header="Hours" Binding="{Binding ShiftStart}" Width="120"/>
                    <DataGridTextColumn Header="Note" Binding="{Binding Note}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
        <TextBlock Grid.Row="2" Text="{Binding ErrorMessage}" Foreground="{DynamicResource DangerBrush}" VerticalAlignment="Bottom"/>
    </Grid>
</UserControl>
