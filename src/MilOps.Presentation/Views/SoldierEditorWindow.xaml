<Window x:Class="MilOps.Presentation.Views.SoldierEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:v="clr-namespace:MilOps.Presentation.Views"
        Title="ویرایش سرباز"
        Width="480" SizeToContent="Height" MaxHeight="780"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource SurfaceBrush}">
    <Border CornerRadius="0" ClipToBounds="True">
        <DockPanel>

            <!-- Gradient header -->
            <Border DockPanel.Dock="Top" Padding="24,20">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#163A5C" Offset="0"/>
                        <GradientStop Color="#1F4E79" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <DockPanel>
                    <Border DockPanel.Dock="Right" Width="48" Height="48" CornerRadius="24"
                            Background="#22FFFFFF" VerticalAlignment="Center">
                        <TextBlock Text="👤" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center" Margin="0,0,14,0">
                        <TextBlock Text="{Binding WindowTitle, FallbackValue='افزودن / ویرایش سرباز'}"
                                   Foreground="White" FontSize="17" FontWeight="Bold"/>
                        <TextBlock Text="اطلاعات پرسنلی را وارد نمایید"
                                   Foreground="#90B8D8" FontSize="11" Margin="0,4,0,0"/>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Bottom action bar -->
            <Border DockPanel.Dock="Bottom" Background="#F4F7FA"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0"
                    Padding="24,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Grid.ColumnSpan="2"
                               Text="{Binding ErrorMessage}" TextWrapping="Wrap"
                               Foreground="{DynamicResource DangerBrush}" Margin="0,0,0,10"
                               Visibility="{Binding ErrorMessage, Converter={StaticResource NullToCollapsedConverter}}"/>
                    <Button Grid.Column="0" Content="ذخیره" Style="{StaticResource PrimaryButton}"
                            Command="{Binding SaveCommand}" IsDefault="True"
                            IsEnabled="{Binding IsNotBusy}" Padding="0,11" Margin="0,0,8,0"/>
                    <Button Grid.Column="1" Content="انصراف" Style="{StaticResource SecondaryButton}"
                            Command="{Binding CancelCommand}" IsCancel="True" Padding="0,11" Margin="8,0,0,0"/>
                </Grid>
            </Border>

            <!-- Scrollable field area -->
            <ScrollViewer VerticalScrollBarVisibility="Auto" Background="White">
                <StackPanel Margin="28,20" FlowDirection="RightToLeft">

                    <!-- Row: نام + نام خانوادگی -->
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="نام *" Style="{StaticResource FieldLabel}" Margin="0,0,0,5"/>
                            <TextBox Text="{Binding FirstName, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBlock Style="{StaticResource FieldError}" Text="{Binding FieldErrors[FirstName]}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="نام خانوادگی *" Style="{StaticResource FieldLabel}" Margin="0,0,0,5"/>
                            <TextBox Text="{Binding LastName, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBlock Style="{StaticResource FieldError}" Text="{Binding FieldErrors[LastName]}"/>
                        </StackPanel>
                    </Grid>

                    <!-- Row: نام پدر + درجه -->
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="نام پدر" Style="{StaticResource FieldLabel}" Margin="0,0,0,5"/>
                            <TextBox Text="{Binding FatherName, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBlock Style="{StaticResource FieldError}" Text="{Binding FieldErrors[FatherName]}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="درجه *" Style="{StaticResource FieldLabel}" Margin="0,0,0,5"/>
                            <TextBox Text="{Binding Rank, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBlock Style="{StaticResource FieldError}" Text="{Binding FieldErrors[Rank]}"/>
                        </StackPanel>
                    </Grid>

                    <!-- Row: کد ملی + کد پرسنلی -->
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="کد ملی *" Style="{StaticResource FieldLabel}" Margin="0,0,0,5"/>
                            <TextBox Text="{Binding NationalCode, UpdateSourceTrigger=PropertyChanged}"
                                     FlowDirection="LeftToRight"/>
                            <TextBlock Style="{StaticResource FieldError}" Text="{Binding FieldErrors[NationalCode]}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="کد پرسنلی *" Style="{StaticResource FieldLabel}" Margin="0,0,0,5"/>
                            <TextBox Text="{Binding PersonnelCode, UpdateSourceTrigger=PropertyChanged}"
                                     FlowDirection="LeftToRight"/>
                            <TextBlock Style="{StaticResource FieldError}" Text="{Binding FieldErrors[PersonnelCode]}"/>
                        </StackPanel>
                    </Grid>

                    <!-- Row: یگان/بخش + وضعیت سلامت -->
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="یگان / بخش" Style="{StaticResource FieldLabel}" Margin="0,0,0,5"/>
                            <TextBox Text="{Binding DepartmentName, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="وضعیت سلامت *" Style="{StaticResource FieldLabel}" Margin="0,0,0,5"/>
                            <ComboBox ItemsSource="{Binding HealthTypes}" SelectedItem="{Binding HealthType}"/>
                        </StackPanel>
                    </Grid>

                    <!-- Divider -->
                    <Border Height="1" Background="{DynamicResource BorderBrush}" Margin="0,4,0,16"/>

                    <!-- Dates row -->
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="تاریخ ورود" Style="{StaticResource FieldLabel}" Margin="0,0,0,5"/>
                            <v:JalaliDatePicker SelectedDate="{Binding EntryDate}"/>
                            <TextBlock Style="{StaticResource FieldError}" Text="{Binding FieldErrors[EntryDate]}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="شروع خدمت *" Style="{StaticResource FieldLabel}" Margin="0,0,0,5"/>
                            <v:JalaliDatePicker SelectedDate="{Binding ServiceStartDate}"/>
                            <TextBlock Style="{StaticResource FieldError}" Text="{Binding FieldErrors[ServiceStartDate]}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="4">
                            <TextBlock Text="پایان خدمت *" Style="{StaticResource FieldLabel}" Margin="0,0,0,5"/>
                            <v:JalaliDatePicker SelectedDate="{Binding ServiceEndDate}"/>
                            <TextBlock Style="{StaticResource FieldError}" Text="{Binding FieldErrors[ServiceEndDate]}"/>
                        </StackPanel>
                    </Grid>

                    <!-- Active checkbox (LTR so RTL doesn't mirror the tick box) -->
                    <CheckBox Content="فعال — آماده به خدمت" IsChecked="{Binding IsActive}"
                              Margin="0,4,0,20" FlowDirection="LeftToRight"/>

                </StackPanel>
            </ScrollViewer>

        </DockPanel>
    </Border>
</Window>
