<UserControl x:Class="MilOps.Presentation.Views.LeavesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:v="clr-namespace:MilOps.Presentation.Views"
             FlowDirection="RightToLeft"
             Loaded="LeavesView_Loaded">
    <Border Margin="16" CornerRadius="12" ClipToBounds="True"
            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
        <DockPanel>

            <!-- Header -->
            <Border DockPanel.Dock="Top" Padding="22,18">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#145A32" Offset="0"/>
                        <GradientStop Color="#1E8449" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <DockPanel>
                    <Border DockPanel.Dock="Right" Width="52" Height="52" CornerRadius="26"
                            Background="#22FFFFFF" VerticalAlignment="Center">
                        <TextBlock Text="🏖" FontSize="26" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center" Margin="0,0,16,0">
                        <TextBlock Text="مدیریت مرخصی" Foreground="White" FontSize="20" FontWeight="Bold"/>
                        <TextBlock Text="ثبت و پیگیری مرخصی‌های پرسنل" Foreground="#A8DFC0" FontSize="12" Margin="0,4,0,0"/>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- New leave request form -->
            <Border DockPanel.Dock="Top" Background="White" Padding="16,14"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,12,0">
                        <TextBlock Text="شناسه سرباز" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding NewSoldierId, UpdateSourceTrigger=PropertyChanged}" Width="90"/>
                        <TextBlock Style="{StaticResource FieldError}" Text="{Binding FieldErrors[SoldierId]}" MaxWidth="90"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="0,0,12,0">
                        <TextBlock Text="شروع مرخصی" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
                        <v:JalaliDatePicker SelectedDate="{Binding NewStart}" Width="140"/>
                        <TextBlock Style="{StaticResource FieldError}" Text="{Binding FieldErrors[StartDate]}" MaxWidth="140"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Margin="0,0,12,0">
                        <TextBlock Text="پایان مرخصی" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
                        <v:JalaliDatePicker SelectedDate="{Binding NewEnd}" Width="140"/>
                        <TextBlock Style="{StaticResource FieldError}" Text="{Binding FieldErrors[EndDate]}" MaxWidth="140"/>
                    </StackPanel>
                    <StackPanel Grid.Column="3" Margin="0,0,12,0">
                        <TextBlock Text="علت" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding NewReason, UpdateSourceTrigger=PropertyChanged}" Width="180"/>
                        <TextBlock Style="{StaticResource FieldError}" Text="{Binding FieldErrors[Reason]}" MaxWidth="180"/>
                    </StackPanel>
                    <Button Grid.Column="5" Content="＋ درخواست مرخصی" Style="{StaticResource AccentButton}"
                            Command="{Binding RequestCommand}" Padding="14,7" VerticalAlignment="Top" Margin="0,20,0,0"/>
                </Grid>
            </Border>

            <!-- Action toolbar -->
            <Border DockPanel.Dock="Top" Background="#F8FAFC" Padding="14,10"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                <StackPanel Orientation="Horizontal">
                    <Button Content="✓ تأیید" Style="{StaticResource AccentButton}"
                            Command="{Binding ApproveCommand}" Padding="14,7" Margin="0,0,8,0"/>
                    <Button Content="✕ رد" Style="{StaticResource DangerButton}"
                            Command="{Binding RejectCommand}" Padding="14,7" Margin="0,0,8,0"/>
                    <Button Content="🖨 چاپ" Style="{StaticResource SecondaryButton}"
                            Command="{Binding PrintCommand}" Padding="14,7" Margin="0,0,8,0"/>
                    <Button Content="بازخوانی" Style="{StaticResource SecondaryButton}"
                            Command="{Binding LoadCommand}" Padding="14,7" Margin="0,0,16,0"/>
                    <TextBlock Text="فیلتر وضعیت:" Style="{StaticResource FieldLabel}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <ComboBox ItemsSource="{Binding Statuses}" SelectedItem="{Binding StatusFilter}" Width="130"/>
                    <Button Content="✕" Style="{StaticResource SecondaryButton}"
                            Command="{Binding ClearStatusFilterCommand}"
                            ToolTip="حذف فیلتر وضعیت" Padding="8,7" Margin="4,0,0,0"/>
                </StackPanel>
            </Border>

            <!-- Error -->
            <TextBlock DockPanel.Dock="Bottom" Text="{Binding ErrorMessage}"
                       Foreground="{DynamicResource DangerBrush}" Margin="14,6,14,0" TextWrapping="Wrap"
                       Visibility="{Binding ErrorMessage, Converter={StaticResource NullToCollapsedConverter}}"/>

            <!-- Data -->
            <DataGrid FlowDirection="RightToLeft"
                      ItemsSource="{Binding Items}" SelectedItem="{Binding Selected}"
                      AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="شناسه"    Binding="{Binding Id}"                                              Width="60"/>
                    <DataGridTextColumn Header="سرباز"    Binding="{Binding SoldierId}"                                       Width="80"/>
                    <DataGridTextColumn Header="شروع"     Binding="{Binding StartDate, Converter={StaticResource JalaliDateConverter}}" Width="120"/>
                    <DataGridTextColumn Header="پایان"    Binding="{Binding EndDate,   Converter={StaticResource JalaliDateConverter}}" Width="120"/>
                    <DataGridTextColumn Header="وضعیت"    Binding="{Binding Status, Converter={StaticResource EnumDescriptionConverter}}"   Width="100"/>
                    <DataGridTextColumn Header="علت"      Binding="{Binding Reason}"                                          Width="*"/>
                </DataGrid.Columns>
            </DataGrid>

        </DockPanel>
    </Border>
</UserControl>
