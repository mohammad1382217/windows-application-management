<UserControl x:Class="MilOps.Presentation.Views.WeaponsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FlowDirection="RightToLeft"
             Loaded="WeaponsView_Loaded">
    <DockPanel Margin="16">

        <!-- Header -->
        <Border DockPanel.Dock="Top" CornerRadius="12,12,0,0" Padding="22,18" ClipToBounds="True">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#6B1A1A" Offset="0"/>
                    <GradientStop Color="#9B2335" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <DockPanel>
                <Border DockPanel.Dock="Right" Width="52" Height="52" CornerRadius="26"
                        Background="#22FFFFFF" VerticalAlignment="Center">
                    <TextBlock Text="🔫" FontSize="26" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel VerticalAlignment="Center" Margin="0,0,16,0">
                    <TextBlock Text="تسلیحات و مهمات" Foreground="White" FontSize="20" FontWeight="Bold"/>
                    <TextBlock Text="ثبت، تخصیص و ردیابی سلاح‌های یگان" Foreground="#F0B0B8" FontSize="12" Margin="0,4,0,0"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Add weapon form -->
        <Border DockPanel.Dock="Top" Background="White" Padding="16,14"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1,0,1,1">
            <StackPanel Orientation="Horizontal">
                <Button Content="＋ ثبت سلاح" Style="{StaticResource AccentButton}"
                        Command="{Binding AddCommand}" Padding="14,7" Margin="0,0,16,0"/>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="مدل:" Style="{StaticResource FieldLabel}" Margin="0,0,6,0"/>
                    <TextBox Text="{Binding NewModel, UpdateSourceTrigger=PropertyChanged}" Width="110" Margin="0,0,12,0"/>
                    <TextBlock Text="نوع:" Style="{StaticResource FieldLabel}" Margin="0,0,6,0"/>
                    <ComboBox ItemsSource="{Binding WeaponTypes}" SelectedItem="{Binding NewWeaponType}" Width="120" Margin="0,0,12,0"/>
                    <TextBlock Text="شماره سلاح:" Style="{StaticResource FieldLabel}" Margin="0,0,6,0"/>
                    <StackPanel>
                        <TextBox Text="{Binding NewWeaponNumber, UpdateSourceTrigger=PropertyChanged}" Width="130"/>
                        <TextBlock Style="{StaticResource FieldError}" Text="{Binding FieldErrors[WeaponNumber]}" MaxWidth="130"/>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Action toolbar -->
        <Border DockPanel.Dock="Top" Background="#F8FAFC" Padding="14,10"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1,0,1,1">
            <StackPanel Orientation="Horizontal">
                <Button Content="تخصیص به سرباز" Style="{StaticResource PrimaryButton}"
                        Command="{Binding IssueCommand}" Padding="14,7" Margin="0,0,8,0"/>
                <Button Content="بازگرداندن" Style="{StaticResource SecondaryButton}"
                        Command="{Binding ReturnCommand}" Padding="14,7" Margin="0,0,8,0"/>
                <Button Content="سابقه" Style="{StaticResource SecondaryButton}"
                        Command="{Binding HistoryCommand}" Padding="14,7" Margin="0,0,8,0"/>
                <Button Content="چاپ همه" Style="{StaticResource SecondaryButton}"
                        Command="{Binding PrintAllCommand}" Padding="14,7"/>
            </StackPanel>
        </Border>

        <!-- Error -->
        <TextBlock DockPanel.Dock="Bottom" Text="{Binding ErrorMessage}"
                   Foreground="{DynamicResource DangerBrush}" Margin="0,6,0,0" TextWrapping="Wrap"
                   Visibility="{Binding ErrorMessage, Converter={StaticResource NullToCollapsedConverter}}"/>

        <!-- Data -->
        <Border CornerRadius="0,0,12,12" ClipToBounds="True"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1,0,1,1">
            <DataGrid FlowDirection="RightToLeft"
                      ItemsSource="{Binding Items}" SelectedItem="{Binding Selected}"
                      AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="شماره سلاح"     Binding="{Binding WeaponNumber}"                 Width="140"/>
                    <DataGridTextColumn Header="نوع"             Binding="{Binding Type,   Converter={StaticResource EnumDescriptionConverter}}"   Width="120"/>
                    <DataGridTextColumn Header="وضعیت"           Binding="{Binding Status, Converter={StaticResource EnumDescriptionConverter}}"   Width="110"/>
                    <DataGridTextColumn Header="مدل"             Binding="{Binding Model}"                        Width="120"/>
                    <DataGridTextColumn Header="تخصیص‌یافته به"  Binding="{Binding CurrentlyAssignedSoldierId}"   Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

    </DockPanel>
</UserControl>
