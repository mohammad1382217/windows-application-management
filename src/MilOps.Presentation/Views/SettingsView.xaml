<UserControl x:Class="MilOps.Presentation.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FlowDirection="RightToLeft">
    <Border Margin="16" CornerRadius="12" ClipToBounds="True"
            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
        <DockPanel>

            <!-- Header -->
            <Border DockPanel.Dock="Top" Padding="22,18">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#3E3E46" Offset="0"/>
                        <GradientStop Color="#565661" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <DockPanel>
                    <Border DockPanel.Dock="Right" Width="52" Height="52" CornerRadius="26"
                            Background="#22FFFFFF" VerticalAlignment="Center">
                        <TextBlock Text="⚙" FontSize="26" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center" Margin="0,0,16,0">
                        <TextBlock Text="تنظیمات" Foreground="White" FontSize="20" FontWeight="Bold"/>
                        <TextBlock Text="تنظیمات محلی برنامه روی این دستگاه" Foreground="#C8C8D0" FontSize="12" Margin="0,4,0,0"/>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Settings form -->
            <StackPanel DockPanel.Dock="Top" Background="White" Margin="0" Orientation="Vertical">
                <Border Padding="20,18" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                    <StackPanel>
                        <TextBlock Text="پوشه پیش‌فرض ذخیره خروجی PDF" Style="{StaticResource FieldLabel}" Margin="0,0,0,8"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Text="{Binding ExportFolder}" IsReadOnly="True"
                                     FlowDirection="LeftToRight" Margin="0,0,10,0"/>
                            <Button Grid.Column="1" Content="انتخاب پوشه" Style="{StaticResource SecondaryButton}"
                                    Command="{Binding BrowseFolderCommand}" Padding="16,8"/>
                        </Grid>
                        <TextBlock Text="این پوشه به‌صورت پیش‌فرض هنگام ذخیرهٔ خروجی PDF از هر بخش برنامه باز می‌شود."
                                   Foreground="{DynamicResource MutedBrush}" FontSize="11" Margin="0,8,0,0" TextWrapping="Wrap"/>
                        <Button Content="ذخیره" Style="{StaticResource PrimaryButton}"
                                Command="{Binding SaveCommand}" Padding="20,9"
                                HorizontalAlignment="Left" Margin="0,16,0,0"/>
                    </StackPanel>
                </Border>
            </StackPanel>

        </DockPanel>
    </Border>
</UserControl>
