<UserControl x:Class="MilOps.Presentation.Views.AuditView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Loaded="AuditView_Loaded">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource Card}" Margin="0,0,0,12" Padding="12">
            <StackPanel Orientation="Horizontal">
                <StackPanel Margin="0,0,12,0">
                    <TextBlock Text="از تاریخ:" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding From, Converter={StaticResource JalaliDateConverter}, UpdateSourceTrigger=LostFocus}" Width="120"/>
                    <TextBlock Style="{StaticResource Caption}" Text="۱۴۰۳/۰۳/۰۷"/>
                </StackPanel>
                <StackPanel Margin="0,0,12,0">
                    <TextBlock Text="تا تاریخ:" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding To, Converter={StaticResource JalaliDateConverter}, UpdateSourceTrigger=LostFocus}" Width="120"/>
                    <TextBlock Style="{StaticResource Caption}" Text="۱۴۰۳/۰۳/۰۷"/>
                </StackPanel>
                <StackPanel Margin="0,0,12,0">
                    <TextBlock Text="عملیات:" Style="{StaticResource FieldLabel}"/>
                    <ComboBox ItemsSource="{Binding Actions}" SelectedItem="{Binding ActionFilter}" Width="150" Padding="4"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom">
                    <Button Content="جست‌وجو" Style="{StaticResource PrimaryButton}" Command="{Binding LoadCommand}" Margin="0,0,8,0"/>
                    <Button Content="بررسی صحت زنجیره" Style="{StaticResource SecondaryButton}" Command="{Binding VerifyCommand}" Margin="0,0,8,0"/>
                    <Button Content="چاپ" Style="{StaticResource SecondaryButton}" Command="{Binding PrintCommand}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource Card}" Padding="0">
            <DataGrid ItemsSource="{Binding Items}" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ترتیب" Binding="{Binding Sequence}" Width="60"/>
                    <DataGridTextColumn Header="زمان" Binding="{Binding OccurredAtUtc, Converter={StaticResource JalaliDateTimeConverter}}" Width="160"/>
                    <DataGridTextColumn Header="عملیات" Binding="{Binding Action}" Width="140"/>
                    <DataGridTextColumn Header="کاربر" Binding="{Binding Username}" Width="120"/>
                    <DataGridTextColumn Header="موجودیت" Binding="{Binding EntityType}" Width="120"/>
                    <DataGridTextColumn Header="جزئیات" Binding="{Binding Details}" Width="*"/>
                    <DataGridTextColumn Header="درهم‌سازی" Binding="{Binding RowHashPreview}" Width="110"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
        <TextBlock Grid.Row="2" Text="{Binding ErrorMessage}" Foreground="{DynamicResource DangerBrush}" VerticalAlignment="Bottom"/>
    </Grid>
</UserControl>
