<UserControl x:Class="MilOps.Presentation.Views.AuditView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:v="clr-namespace:MilOps.Presentation.Views"
             FlowDirection="RightToLeft"
             Loaded="AuditView_Loaded">
    <Border Margin="16" CornerRadius="12" ClipToBounds="True"
            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
        <DockPanel>

            <!-- Header -->
            <Border DockPanel.Dock="Top" Padding="22,18">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#1C2833" Offset="0"/>
                        <GradientStop Color="#2C3E50" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <DockPanel>
                    <Border DockPanel.Dock="Right" Width="52" Height="52" CornerRadius="26"
                            Background="#22FFFFFF" VerticalAlignment="Center">
                        <TextBlock Text="📜" FontSize="26" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center" Margin="0,0,16,0">
                        <TextBlock Text="گزارش حسابرسی" Foreground="White" FontSize="20" FontWeight="Bold"/>
                        <TextBlock Text="سوابق تمامی عملیات و رویدادهای سامانه" Foreground="#90A8B8" FontSize="12" Margin="0,4,0,0"/>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Filter form -->
            <Border DockPanel.Dock="Top" Background="White" Padding="16,14"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,12,0">
                        <TextBlock Text="از تاریخ" Style="{StaticResource FieldLabel}" Margin="0,0,0,5"/>
                        <v:JalaliDatePicker SelectedDate="{Binding From}" Width="150"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="0,0,12,0">
                        <TextBlock Text="تا تاریخ" Style="{StaticResource FieldLabel}" Margin="0,0,0,5"/>
                        <v:JalaliDatePicker SelectedDate="{Binding To}" Width="150"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Margin="0,0,12,0">
                        <TextBlock Text="نوع عملیات" Style="{StaticResource FieldLabel}" Margin="0,0,0,5"/>
                        <StackPanel Orientation="Horizontal">
                            <Grid>
                                <ComboBox ItemsSource="{Binding Actions}" SelectedItem="{Binding ActionFilter}" Width="160"/>
                                <TextBlock Text="همه عملیات‌ها" IsHitTestVisible="False"
                                           Foreground="{DynamicResource MutedBrush}" FontSize="12"
                                           VerticalAlignment="Center" Margin="12,0,12,0"
                                           Visibility="{Binding ActionFilter, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=inverse}"/>
                            </Grid>
                            <Button Content="✕" Style="{StaticResource SecondaryButton}"
                                    Command="{Binding ClearActionFilterCommand}"
                                    ToolTip="حذف فیلتر عملیات" Padding="8,5" Margin="4,0,0,0"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Bottom">
                        <Button Content="🔍 جست‌وجو" Style="{StaticResource PrimaryButton}"
                                Command="{Binding LoadCommand}" Padding="14,7" Margin="0,0,8,0"/>
                        <Button Content="🛡 بررسی سلامت گزارش" Style="{StaticResource SecondaryButton}"
                                Command="{Binding VerifyCommand}" Padding="14,7" Margin="0,0,8,0"
                                ToolTip="بررسی می‌کند که هیچ‌یک از سوابق حسابرسی ویرایش یا حذف نشده باشد (زنجیره امضای HMAC)"/>
                        <Button Content="⬇ خروجی PDF" Style="{StaticResource PrimaryButton}"
                                Command="{Binding ExportPdfCommand}" Padding="14,7" Margin="0,0,8,0"
                                ToolTip="ذخیره گزارش به‌صورت فایل PDF در قطع A5 — بدون نیاز به چاپگر"/>
                        <Button Content="🖨 چاپ" Style="{StaticResource SecondaryButton}"
                                Command="{Binding PrintCommand}" Padding="14,7"
                                ToolTip="چاپ مستقیم با چاپگر متصل"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Error -->
            <TextBlock DockPanel.Dock="Bottom" Text="{Binding ErrorMessage}"
                       Foreground="{DynamicResource DangerBrush}" Margin="14,6,14,0" TextWrapping="Wrap"
                       Visibility="{Binding ErrorMessage, Converter={StaticResource NullToCollapsedConverter}}"/>

            <!-- Data -->
            <DataGrid FlowDirection="RightToLeft"
                      ItemsSource="{Binding Items}" AutoGenerateColumns="False"
                      IsReadOnly="True" CanUserAddRows="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ترتیب"     Binding="{Binding Sequence}"                                               Width="70"/>
                    <DataGridTextColumn Header="زمان"       Binding="{Binding OccurredAtUtc, Converter={StaticResource JalaliDateTimeConverter}}" Width="160"/>
                    <DataGridTextColumn Header="عملیات"     Binding="{Binding Action, Converter={StaticResource EnumDescriptionConverter}}"   Width="150"/>
                    <DataGridTextColumn Header="کاربر"      Binding="{Binding Username}"                                              Width="120"/>
                    <DataGridTextColumn Header="موجودیت"    Binding="{Binding EntityType}"                                            Width="120"/>
                    <DataGridTextColumn Header="جزئیات"     Binding="{Binding Details}"                                               Width="*"/>
                    <DataGridTextColumn Header="درهم‌سازی"  Binding="{Binding RowHashPreview}"                                        Width="120"/>
                </DataGrid.Columns>
            </DataGrid>

        </DockPanel>
    </Border>
</UserControl>
