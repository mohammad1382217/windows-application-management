<UserControl x:Class="MilOps.Presentation.Views.AuditView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Loaded="AuditView_Loaded">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
            <TextBlock Text="From (UTC):" Style="{StaticResource FieldLabel}"/>
            <DatePicker SelectedDate="{Binding From}" Margin="0,0,8,0"/>
            <TextBlock Text="To (UTC):" Style="{StaticResource FieldLabel}"/>
            <DatePicker SelectedDate="{Binding To}" Margin="0,0,8,0"/>
            <TextBlock Text="Action:" Style="{StaticResource FieldLabel}"/>
            <ComboBox ItemsSource="{Binding Actions}" SelectedItem="{Binding ActionFilter}" Width="150" Padding="4"/>
            <Button Content="Query" Style="{StaticResource PrimaryButton}" Command="{Binding LoadCommand}" Margin="8,0,0,0"/>
            <Button Content="✔ Verify Chain" Style="{StaticResource PrimaryButton}" Command="{Binding VerifyCommand}" Margin="8,0,0,0"/>
            <Button Content="🖨 Print" Style="{StaticResource PrimaryButton}" Command="{Binding PrintCommand}"/>
        </StackPanel>

        <Border Grid.Row="2" Background="White" BorderBrush="#FFE0E0E0" BorderThickness="1">
            <DataGrid ItemsSource="{Binding Items}" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Seq" Binding="{Binding Sequence}" Width="60"/>
                    <DataGridTextColumn Header="When (UTC)" Binding="{Binding OccurredAtUtc, StringFormat=u}" Width="160"/>
                    <DataGridTextColumn Header="Action" Binding="{Binding Action}" Width="140"/>
                    <DataGridTextColumn Header="User" Binding="{Binding Username}" Width="120"/>
                    <DataGridTextColumn Header="Entity" Binding="{Binding EntityType}" Width="120"/>
                    <DataGridTextColumn Header="Details" Binding="{Binding Details}" Width="*"/>
                    <DataGridTextColumn Header="Hash" Binding="{Binding RowHashPreview}" Width="110"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
        <TextBlock Grid.Row="2" Text="{Binding ErrorMessage}" Foreground="{DynamicResource DangerBrush}" VerticalAlignment="Bottom"/>
    </Grid>
</UserControl>
