<Window x:Class="MilOps.Presentation.Views.PasswordPromptDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="گذرواژه جدید"
        Width="400" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="White">
    <StackPanel FlowDirection="RightToLeft">

        <!-- Header -->
        <Border Padding="20,16">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#1C3558" Offset="0"/>
                    <GradientStop Color="#22487A" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <TextBlock x:Name="PromptText" Foreground="White" FontSize="14"
                       FontWeight="SemiBold" TextWrapping="Wrap"/>
        </Border>

        <!-- Input area: masked, unlike InputDialog's plain TextBox — a
             password shouldn't be shown in clear text on screen. -->
        <StackPanel Margin="20,18,20,0">
            <PasswordBox x:Name="ValueBox" Padding="10,9" FontSize="13" FlowDirection="LeftToRight"/>
            <TextBlock x:Name="HintText" Foreground="{DynamicResource MutedBrush}" FontSize="11"
                       Margin="0,6,0,0"/>
        </StackPanel>

        <!-- Actions -->
        <Grid Margin="20,14,20,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Content="تأیید" Style="{StaticResource PrimaryButton}"
                    Padding="0,10" IsDefault="True" Click="Ok_Click"/>
            <Button Grid.Column="2" Content="انصراف" Style="{StaticResource SecondaryButton}"
                    Padding="0,10" IsCancel="True" Click="Cancel_Click"/>
        </Grid>

    </StackPanel>
</Window>
