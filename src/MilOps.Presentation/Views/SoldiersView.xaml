<UserControl x:Class="MilOps.Presentation.Views.SoldiersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FlowDirection="RightToLeft"
             Loaded="SoldiersView_Loaded">
    <Border Margin="16" CornerRadius="12" ClipToBounds="True"
            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
        <DockPanel>

            <!-- Header -->
            <Border DockPanel.Dock="Top" Padding="22,18">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#163A5C" Offset="0"/>
                        <GradientStop Color="#1F4E79" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <DockPanel>
                    <Border DockPanel.Dock="Right" Width="52" Height="52" CornerRadius="26"
                            Background="#22FFFFFF" VerticalAlignment="Center">
                        <TextBlock Text="👥" FontSize="26" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center" Margin="0,0,16,0">
                        <TextBlock Text="سربازان" Foreground="White" FontSize="20" FontWeight="Bold"/>
                        <TextBlock Text="فهرست و مدیریت پرسنل یگان" Foreground="#90B8D8" FontSize="12" Margin="0,4,0,0"/>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Toolbar -->
            <Border DockPanel.Dock="Top" Background="White" Padding="14,12"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Actions (visual right in RTL grid) -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <Button Content="＋ افزودن" Style="{StaticResource AccentButton}"
                                Command="{Binding AddCommand}" Padding="14,7" Margin="0,0,8,0"/>
                        <Button Content="✎ ویرایش" Style="{StaticResource PrimaryButton}"
                                Command="{Binding EditCommand}" Padding="14,7" Margin="0,0,8,0"/>
                        <Button Content="✕ حذف" Style="{StaticResource DangerButton}"
                                Command="{Binding DeleteCommand}" Padding="14,7" Margin="0,0,8,0"/>
                        <Button Content="چاپ" Style="{StaticResource SecondaryButton}"
                                Command="{Binding PrintCommand}" Padding="14,7"/>
                    </StackPanel>

                    <!-- Search + filter (visual left) -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <ComboBox ItemsSource="{Binding HealthTypes}" SelectedItem="{Binding HealthFilter}"
                                  Width="130" Margin="0,0,8,0"/>
                        <TextBox Text="{Binding Search, UpdateSourceTrigger=PropertyChanged}"
                                 Width="200" Padding="10,7" FlowDirection="RightToLeft"/>
                        <Button Content="🔍" Style="{StaticResource SecondaryButton}"
                                Command="{Binding LoadCommand}" Padding="12,7" Margin="8,0,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Error -->
            <TextBlock DockPanel.Dock="Bottom" Text="{Binding ErrorMessage}"
                       Foreground="{DynamicResource DangerBrush}" Margin="14,6,14,0" TextWrapping="Wrap"
                       Visibility="{Binding ErrorMessage, Converter={StaticResource NullToCollapsedConverter}}"/>

            <!-- Data -->
            <DataGrid FlowDirection="RightToLeft"
                      ItemsSource="{Binding Items}" SelectedItem="{Binding Selected}"
                      AutoGenerateColumns="False" IsReadOnly="True"
                      CanUserAddRows="False" CanUserDeleteRows="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="کد پرسنلی"  Binding="{Binding PersonnelCode}"  Width="100"/>
                    <DataGridTextColumn Header="نام"         Binding="{Binding FirstName}"       Width="110"/>
                    <DataGridTextColumn Header="نام خانوادگی" Binding="{Binding LastName}"       Width="130"/>
                    <DataGridTextColumn Header="درجه"        Binding="{Binding Rank}"            Width="100"/>
                    <DataGridTextColumn Header="کد ملی"      Binding="{Binding NationalCode}"    Width="120"/>
                    <DataGridTextColumn Header="یگان/بخش"    Binding="{Binding DepartmentName}"  Width="120"/>
                    <DataGridTextColumn Header="سلامت"       Binding="{Binding HealthType, Converter={StaticResource EnumDescriptionConverter}}"      Width="100"/>
                    <DataGridCheckBoxColumn Header="فعال"    Binding="{Binding IsActive}"        Width="60"/>
                </DataGrid.Columns>
            </DataGrid>

        </DockPanel>
    </Border>
</UserControl>
