<UserControl x:Class="MilOps.Presentation.Views.SoldiersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Loaded="SoldiersView_Loaded">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" Style="{StaticResource Card}" Margin="0,0,0,12" Padding="12">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="جستجو:" Style="{StaticResource FieldLabel}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox Text="{Binding Search, UpdateSourceTrigger=PropertyChanged}" Width="220" Padding="6,4" Margin="0,0,16,0"/>
                <Button Content="جستجو" Style="{StaticResource PrimaryButton}" Command="{Binding LoadCommand}" Margin="0,0,8,0"/>
                <Button Content="افزودن" Style="{StaticResource AccentButton}" Command="{Binding AddCommand}" Margin="0,0,8,0"/>
                <Button Content="ویرایش" Style="{StaticResource PrimaryButton}" Command="{Binding EditCommand}" Margin="0,0,8,0"/>
                <Button Content="حذف" Style="{StaticResource DangerButton}" Command="{Binding DeleteCommand}" Margin="0,0,8,0"/>
                <Button Content="چاپ" Style="{StaticResource SecondaryButton}" Command="{Binding PrintCommand}"/>
            </StackPanel>
        </Border>

        <!-- Filter -->
        <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,0,0,12" Padding="12">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="وضعیت سلامت:" Style="{StaticResource FieldLabel}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <ComboBox ItemsSource="{Binding HealthTypes}" SelectedItem="{Binding HealthFilter}" Width="140" Padding="4"/>
            </StackPanel>
        </Border>

        <!-- Grid -->
        <Border Grid.Row="2" Style="{StaticResource Card}" Padding="0">
            <DataGrid ItemsSource="{Binding Items}" SelectedItem="{Binding Selected}"
                      AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal" CanUserAddRows="False" CanUserDeleteRows="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="کد پرسنلی" Binding="{Binding PersonnelCode}" Width="100"/>
                    <DataGridTextColumn Header="نام" Binding="{Binding FirstName}" Width="120"/>
                    <DataGridTextColumn Header="نام خانوادگی" Binding="{Binding LastName}" Width="140"/>
                    <DataGridTextColumn Header="درجه" Binding="{Binding Rank}" Width="100"/>
                    <DataGridTextColumn Header="کد ملی" Binding="{Binding NationalCode}" Width="120"/>
                    <DataGridTextColumn Header="یگان/بخش" Binding="{Binding DepartmentName}" Width="120"/>
                    <DataGridTextColumn Header="وضعیت سلامت" Binding="{Binding HealthType}" Width="110"/>
                    <DataGridCheckBoxColumn Header="فعال" Binding="{Binding IsActive}" Width="60"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <TextBlock Grid.Row="3" Text="{Binding ErrorMessage}" Foreground="{DynamicResource DangerBrush}" Margin="0,8,0,0"/>
    </Grid>
</UserControl>
