<UserControl x:Class="MilOps.Presentation.Views.SoldiersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FlowDirection="RightToLeft"
             Loaded="SoldiersView_Loaded">
    <Border Margin="16" CornerRadius="12" ClipToBounds="True"
            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
        <DockPanel>

            <!-- Header -->
            <Border DockPanel.Dock="Top" Padding="22,18">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#163A5C" Offset="0"/>
                        <GradientStop Color="#1F4E79" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <DockPanel>
                    <Border DockPanel.Dock="Right" Width="52" Height="52" CornerRadius="26"
                            Background="#22FFFFFF" VerticalAlignment="Center">
                        <TextBlock Text="👥" FontSize="26" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center" Margin="0,0,16,0">
                        <TextBlock Text="سربازان" Foreground="White" FontSize="20" FontWeight="Bold"/>
                        <TextBlock Text="فهرست و مدیریت پرسنل یگان" Foreground="#90B8D8" FontSize="12" Margin="0,4,0,0"/>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Toolbar -->
            <Border DockPanel.Dock="Top" Background="White" Padding="14,12"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Actions (visual right in RTL grid) -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <Button Content="＋ افزودن" Style="{StaticResource AccentButton}"
                                Command="{Binding AddCommand}" Margin="0,0,8,0"/>
                        <Button Content="✎ ویرایش" Style="{StaticResource PrimaryButton}"
                                Command="{Binding EditCommand}" Margin="0,0,8,0"/>
                        <Button Content="✕ حذف" Style="{StaticResource DangerButton}"
                                Command="{Binding DeleteCommand}"/>
                        <Border Style="{StaticResource ToolbarSeparator}" Margin="12,4"/>
                        <Button Content="⬇ PDF" Style="{StaticResource SecondaryButton}"
                                Command="{Binding ExportPdfCommand}" Margin="0,0,8,0"
                                ToolTip="ذخیره فهرست به‌صورت فایل PDF — بدون نیاز به چاپگر"/>
                        <Button Content="🖨 چاپ" Style="{StaticResource SecondaryButton}"
                                Command="{Binding PrintCommand}"
                                ToolTip="چاپ مستقیم با چاپگر متصل"/>
                    </StackPanel>

                    <!-- Search + filter (visual left) -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <Grid Margin="0,0,8,0">
                            <ComboBox ItemsSource="{Binding HealthTypes}" SelectedItem="{Binding HealthFilter}"
                                      ToolTip="فیلتر وضعیت سلامت" Width="140"/>
                            <!-- Placeholder shown while no filter is selected -->
                            <TextBlock Text="وضعیت سلامت" IsHitTestVisible="False"
                                       Foreground="{DynamicResource MutedBrush}" FontSize="12"
                                       VerticalAlignment="Center" Margin="12,0,12,0"
                                       Visibility="{Binding HealthFilter, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=inverse}"/>
                        </Grid>
                        <!-- Appears only once a filter is actually applied -->
                        <Button Content="✕" Style="{StaticResource IconButton}"
                                Command="{Binding ClearHealthFilterCommand}"
                                ToolTip="حذف فیلتر سلامت" Margin="0,0,8,0"
                                Visibility="{Binding HealthFilter, Converter={StaticResource NullToVisibilityConverter}}"/>
                        <Grid>
                            <TextBox Style="{StaticResource SearchBox}"
                                     Text="{Binding Search, UpdateSourceTrigger=PropertyChanged}"
                                     Width="230" FlowDirection="RightToLeft"
                                     ToolTip="جست‌وجو در نام، کد ملی و کد پرسنلی — نتیجه خودکار به‌روز می‌شود">
                                <TextBox.InputBindings>
                                    <KeyBinding Key="Return" Command="{Binding LoadCommand}"/>
                                </TextBox.InputBindings>
                            </TextBox>
                            <!-- Placeholder shown while the box is empty (icon lives in the template) -->
                            <TextBlock Text="جست‌وجوی نام، کد ملی، کد پرسنلی…" IsHitTestVisible="False"
                                       Foreground="{DynamicResource MutedBrush}" FontSize="12"
                                       VerticalAlignment="Center" Margin="34,0,28,0"
                                       Visibility="{Binding Search, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=inverse}"/>
                            <!-- Clear lives INSIDE the box, logical end = physical left -->
                            <Button Content="✕" Style="{StaticResource InlineClearButton}"
                                    Command="{Binding ClearSearchCommand}"
                                    ToolTip="پاک‌کردن جست‌وجو"
                                    HorizontalAlignment="Right" Margin="0,0,7,0"
                                    Visibility="{Binding Search, Converter={StaticResource NullToVisibilityConverter}}"/>
                        </Grid>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Error -->
            <TextBlock DockPanel.Dock="Bottom" Text="{Binding ErrorMessage}"
                       Foreground="{DynamicResource DangerBrush}" Margin="14,6,14,0" TextWrapping="Wrap"
                       Visibility="{Binding ErrorMessage, Converter={StaticResource NullToCollapsedConverter}}"/>

            <!-- Shown only when the 200-row server cap actually truncated results,
                 so a partial list is never mistaken for "everyone". -->
            <TextBlock DockPanel.Dock="Top" Text="{Binding ResultCountCaption}"
                       Foreground="{DynamicResource MutedBrush}" FontSize="12" Margin="14,8,14,0"
                       Visibility="{Binding ResultCountCaption, Converter={StaticResource NullToCollapsedConverter}}"/>

            <!-- Data -->
            <Grid>
                <DataGrid FlowDirection="RightToLeft"
                          ItemsSource="{Binding Items}" SelectedItem="{Binding Selected}"
                          AutoGenerateColumns="False" IsReadOnly="True"
                          CanUserAddRows="False" CanUserDeleteRows="False"
                          MouseDoubleClick="DataGrid_MouseDoubleClick">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="کد پرسنلی"  Binding="{Binding PersonnelCode}"  Width="100"/>
                        <DataGridTextColumn Header="نام"         Binding="{Binding FirstName}"       Width="110"/>
                        <DataGridTextColumn Header="نام خانوادگی" Binding="{Binding LastName}"       Width="130"/>
                        <DataGridTextColumn Header="درجه"        Binding="{Binding Rank}"            Width="100"/>
                        <DataGridTextColumn Header="کد ملی"      Binding="{Binding NationalCode}"    Width="120"/>
                        <DataGridTextColumn Header="یگان/بخش"    Binding="{Binding DepartmentName}"  Width="*" MinWidth="120"/>
                        <DataGridTextColumn Header="سلامت"       Binding="{Binding HealthType, Converter={StaticResource EnumDescriptionConverter}}"      Width="100"/>
                        <DataGridCheckBoxColumn Header="فعال"    Binding="{Binding IsActive}"        Width="60"
                                                ElementStyle="{StaticResource GridCheckBox}"/>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Busy overlay: search/print/delete previously gave zero feedback,
                     so a slow operation looked like a frozen screen. -->
                <Border Background="#66FFFFFF"
                        Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisConverter}}">
                    <ProgressBar IsIndeterminate="True" Width="160" Height="4"
                                 VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </Border>
            </Grid>

        </DockPanel>
    </Border>
</UserControl>
