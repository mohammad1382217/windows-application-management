<Window x:Class="MilOps.Presentation.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="سنگر — ورود امن"
        Width="420" SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#1C3558">

    <Grid>
        <!-- Background gradient -->
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#1C3558" Offset="0"/>
                <GradientStop Color="#22487A" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <!-- Login card — no shadow, clean border only -->
        <Border Margin="32,36"
                Background="White"
                CornerRadius="14"
                BorderBrush="#DDE3EC"
                BorderThickness="1"
                Padding="36,32"
                FlowDirection="RightToLeft">
            <StackPanel>

                <!-- Brand -->
                <StackPanel HorizontalAlignment="Center" Margin="0,0,0,32">
                    <Viewbox Width="84" Height="84" HorizontalAlignment="Center">
                        <Viewbox.Effect>
                            <DropShadowEffect Color="#000000" Opacity="0.35" BlurRadius="10" ShadowDepth="3"/>
                        </Viewbox.Effect>
                        <Canvas Width="100" Height="100">
                            <Ellipse Width="100" Height="100" Fill="#0F1E30"/>
                            <Ellipse Canvas.Left="4"  Canvas.Top="4"  Width="92" Height="92"
                                     Stroke="#C9A227" StrokeThickness="2.5" Fill="Transparent"/>
                            <Ellipse Canvas.Left="13" Canvas.Top="13" Width="74" Height="74"
                                     Stroke="#C9A227" StrokeThickness="1"   Fill="Transparent"/>
                            <Path Fill="White"
                                  Data="M 50,12 L 59,37 L 86,38 L 65,55 L 72,81 L 50,66 L 28,81 L 35,55 L 14,38 L 41,37 Z"/>
                            <Ellipse Canvas.Left="45" Canvas.Top="45" Width="10" Height="10"
                                     Fill="#C9A227"/>
                        </Canvas>
                    </Viewbox>
                    <TextBlock Text="سنگر" FontSize="24" FontWeight="Bold"
                               Foreground="{DynamicResource PrimaryBrush}"
                               HorizontalAlignment="Center" Margin="0,12,0,0"/>
                    <TextBlock Text="سامانهٔ مدیریت یگان نظامی"
                               FontSize="12" Foreground="{DynamicResource MutedBrush}"
                               HorizontalAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>

                <!-- Username -->
                <TextBlock Text="نام کاربری" Style="{StaticResource FieldLabel}"
                           FontSize="13" Margin="0,0,0,6"/>
                <TextBox x:Name="UsernameBox"
                         Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                         FontSize="14" Padding="10,9"
                         FlowDirection="LeftToRight"/>
                <TextBlock Style="{StaticResource FieldError}" Text="{Binding FieldErrors[Username]}"/>
                <Border Height="18"/>

                <!-- Password -->
                <TextBlock Text="گذرواژه" Style="{StaticResource FieldLabel}"
                           FontSize="13" Margin="0,0,0,6"/>
                <PasswordBox x:Name="PasswordBox"
                             PasswordChanged="PasswordBox_PasswordChanged"
                             FontSize="14" Padding="10,9"
                             FlowDirection="LeftToRight"/>
                <TextBlock Style="{StaticResource FieldError}" Text="{Binding FieldErrors[Password]}"/>
                <Border Height="28"/>

                <!-- Activation token (revealed on first login of a new account) -->
                <StackPanel Visibility="{Binding IsActivationRequired, Converter={StaticResource BoolToVisConverter}}">
                    <TextBlock Text="توکن فعال‌سازی (دریافتی از فرمانده)"
                               Style="{StaticResource FieldLabel}"
                               FontSize="13" Margin="0,0,0,6"/>
                    <TextBox x:Name="ActivationTokenBox"
                             Text="{Binding ActivationToken, UpdateSourceTrigger=PropertyChanged}"
                             FontSize="13" Padding="10,9"
                             FlowDirection="LeftToRight"/>
                    <Border Height="14"/>
                    <!-- IsDefault here (not on the now-hidden login button below) so
                         Enter submits the form the user is actually looking at. -->
                    <Button Content="فعال‌سازی حساب و ورود"
                            Style="{StaticResource AccentButton}"
                            Command="{Binding ActivateCommand}"
                            IsDefault="{Binding IsActivationRequired}"
                            MinHeight="46" FontSize="14"/>
                    <Border Height="18"/>
                </StackPanel>

                <!-- Login button -->
                <Button Content="ورود به سامانه"
                        Style="{StaticResource PrimaryButton}"
                        Command="{Binding LoginCommand}"
                        IsDefault="{Binding IsActivationRequired, Converter={StaticResource InverseBoolConverter}}"
                        IsEnabled="{Binding IsNotBusy}"
                        MinHeight="46" FontSize="14"
                        Visibility="{Binding IsActivationRequired, Converter={StaticResource InverseBoolToVisConverter}, FallbackValue=Visible}"/>

                <!-- Error message -->
                <TextBlock Text="{Binding Hint}"
                           Foreground="{DynamicResource DangerBrush}"
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           Margin="0,14,0,0"
                           Visibility="{Binding Hint, Converter={StaticResource NullToCollapsedConverter}}"/>

                <!-- Busy indicator -->
                <ProgressBar IsIndeterminate="True" Height="3" Margin="0,14,0,0"
                             Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisConverter}}"/>

            </StackPanel>
        </Border>
    </Grid>
</Window>
