<Window x:Class="MilOps.Presentation.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="میل‌اپس — ورود امن" Height="520" Width="440"
        WindowStartupLocation="CenterScreen" ResizeMode="CanMinimize"
        Background="{DynamicResource SurfaceBrush}">

    <!-- Centered login card with consistent internal padding/rhythm. -->
    <Grid>
        <Border MaxWidth="380" VerticalAlignment="Center" Margin="28"
                Background="White" CornerRadius="12" Padding="32,28"
                BorderBrush="#E6E6E6" BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect Color="#33000000" BlurRadius="18" ShadowDepth="2" Direction="270"/>
            </Border.Effect>

            <StackPanel>
                <!-- Brand header -->
                <Border Background="{DynamicResource PrimaryBrush}" CornerRadius="8"
                        Padding="16,14" Margin="0,0,0,28">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="🛡 میل‌اپس" Foreground="White" FontSize="26"
                                   FontWeight="Bold" HorizontalAlignment="Center"/>
                        <TextBlock Text="سامانه مدیریت یگان نظامی — دسترسی امن"
                                   Foreground="#FFE0E0E0" FontSize="11"
                                   HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Username -->
                <TextBlock Text="نام کاربری" FontWeight="SemiBold" Margin="0,0,0,6"/>
                <TextBox x:Name="UsernameBox" FontSize="14" Padding="10,8" Margin="0,0,0,18"
                         Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"/>

                <!-- Password -->
                <TextBlock Text="گذرواژه" FontWeight="SemiBold" Margin="0,0,0,6"/>
                <PasswordBox x:Name="PasswordBox" FontSize="14" Padding="10,8" Margin="0,0,0,24"
                             PasswordChanged="PasswordBox_PasswordChanged"/>

                <!-- Sign in (IsDefault: Enter submits) -->
                <Button Content="ورود" Style="{StaticResource PrimaryButton}"
                        Command="{Binding LoginCommand}" IsDefault="True"
                        Padding="0,12" FontSize="14" IsEnabled="{Binding IsNotBusy}"/>

                <!-- Error / hint -->
                <TextBlock Text="{Binding Hint}" Foreground="{DynamicResource DangerBrush}"
                           TextWrapping="Wrap" Margin="0,16,0,0"
                           Visibility="{Binding Hint, Converter={StaticResource NullToCollapsedConverter}}"/>

                <!-- Busy indicator -->
                <ProgressBar IsIndeterminate="True" Height="3" Margin="0,16,0,0"
                             Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisConverter}}"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
