<UserControl x:Class="MilOps.Presentation.Views.TokensView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:v="clr-namespace:MilOps.Presentation.Views"
             FlowDirection="RightToLeft"
             Loaded="TokensView_Loaded">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Issue form card -->
        <Border Grid.Row="0" CornerRadius="12" ClipToBounds="True"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="0,0,0,12">
            <DockPanel>
                <!-- Header -->
                <Border DockPanel.Dock="Top" Padding="22,16">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#4A1E7A" Offset="0"/>
                            <GradientStop Color="#6C3AAA" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <DockPanel>
                        <Border DockPanel.Dock="Right" Width="46" Height="46" CornerRadius="23"
                                Background="#22FFFFFF" VerticalAlignment="Center">
                            <TextBlock Text="🔑" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center" Margin="0,0,14,0">
                            <TextBlock Text="توکن‌های فرمانده" Foreground="White" FontSize="18" FontWeight="Bold"/>
                            <TextBlock Text="صدور مجوز خروج موقت از پایگاه" Foreground="#CCA8F0" FontSize="12" Margin="0,3,0,0"/>
                        </StackPanel>
                    </DockPanel>
                </Border>

                <!-- Fields -->
                <Grid Margin="18,16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,10,10">
                        <TextBlock Text="نام" Style="{StaticResource FieldLabel}" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding FirstName}"/>
                        <TextBlock Style="{StaticResource FieldError}" Text="{Binding FieldErrors[FirstName]}"/>
                    </StackPanel>
                    <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,10,10">
                        <TextBlock Text="نام خانوادگی" Style="{StaticResource FieldLabel}" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding LastName}"/>
                        <TextBlock Style="{StaticResource FieldError}" Text="{Binding FieldErrors[LastName]}"/>
                    </StackPanel>
                    <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,10,10">
                        <TextBlock Text="کد ملی" Style="{StaticResource FieldLabel}" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding NationalCode}" FlowDirection="LeftToRight"/>
                        <TextBlock Style="{StaticResource FieldError}" Text="{Binding FieldErrors[NationalCode]}"/>
                    </StackPanel>
                    <StackPanel Grid.Row="0" Grid.Column="3" Margin="0,0,0,10">
                        <TextBlock Text="کد پرسنلی" Style="{StaticResource FieldLabel}" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding PersonnelCode}" FlowDirection="LeftToRight"/>
                        <TextBlock Style="{StaticResource FieldError}" Text="{Binding FieldErrors[PersonnelCode]}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,10,10">
                        <TextBlock Text="درجه" Style="{StaticResource FieldLabel}" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding Rank}"/>
                        <TextBlock Style="{StaticResource FieldError}" Text="{Binding FieldErrors[Rank]}"/>
                    </StackPanel>
                    <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,10,10">
                        <TextBlock Text="شروع خدمت" Style="{StaticResource FieldLabel}" Margin="0,0,0,5"/>
                        <v:JalaliDatePicker SelectedDate="{Binding ServiceStart}"/>
                        <TextBlock Style="{StaticResource FieldError}" Text="{Binding FieldErrors[ServiceStartDate]}"/>
                    </StackPanel>
                    <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,0,10,10">
                        <TextBlock Text="پایان خدمت" Style="{StaticResource FieldLabel}" Margin="0,0,0,5"/>
                        <v:JalaliDatePicker SelectedDate="{Binding ServiceEnd}"/>
                        <TextBlock Style="{StaticResource FieldError}" Text="{Binding FieldErrors[ServiceEndDate]}"/>
                    </StackPanel>
                    <StackPanel Grid.Row="1" Grid.Column="3" Margin="0,0,0,10">
                        <TextBlock Text="هدف مجوز" Style="{StaticResource FieldLabel}" Margin="0,0,0,5"/>
                        <ComboBox ItemsSource="{Binding Purposes}" SelectedItem="{Binding Purpose}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Grid.Column="0" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="اعتبار (روز):" Style="{StaticResource FieldLabel}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBox Text="{Binding ValidDays}" Width="70" FlowDirection="LeftToRight"/>
                        </StackPanel>
                        <TextBlock Style="{StaticResource FieldError}" Text="{Binding FieldErrors[ValidDays]}"/>
                    </StackPanel>
                    <Button Grid.Row="2" Grid.Column="3" Content="🔑 صدور توکن"
                            Style="{StaticResource PrimaryButton}"
                            Command="{Binding GenerateCommand}" IsEnabled="{Binding IsNotBusy}"
                            Padding="0,9" HorizontalAlignment="Stretch"/>
                </Grid>
            </DockPanel>
        </Border>

        <!-- Tokens list -->
        <Border Grid.Row="1" CornerRadius="12" ClipToBounds="True"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
            <DockPanel>
                <Border DockPanel.Dock="Top" Background="White" Padding="14,11"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                    <StackPanel Orientation="Horizontal">
                        <Button Content="✕ ابطال توکن" Style="{StaticResource DangerButton}"
                                Command="{Binding RevokeCommand}" Padding="14,7" Margin="0,0,8,0"/>
                        <Button Content="بازخوانی" Style="{StaticResource SecondaryButton}"
                                Command="{Binding LoadCommand}" Padding="14,7" Margin="0,0,16,0"/>
                        <TextBlock Text="فیلتر:" Style="{StaticResource FieldLabel}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <ComboBox ItemsSource="{Binding Statuses}" SelectedItem="{Binding StatusFilter}" Width="130"/>
                    </StackPanel>
                </Border>

                <TextBlock DockPanel.Dock="Bottom" Text="{Binding ErrorMessage}"
                           Foreground="{DynamicResource DangerBrush}" Margin="14,6,14,0" TextWrapping="Wrap"
                           Visibility="{Binding ErrorMessage, Converter={StaticResource NullToCollapsedConverter}}"/>

                <DataGrid FlowDirection="RightToLeft"
                          ItemsSource="{Binding Items}" SelectedItem="{Binding Selected}"
                          AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="پیش‌نمایش"   Binding="{Binding Preview}"                                            Width="120"/>
                        <DataGridTextColumn Header="نام خانوادگی" Binding="{Binding LastName}"                                          Width="130"/>
                        <DataGridTextColumn Header="کد ملی"       Binding="{Binding NationalCode}"                                      Width="120"/>
                        <DataGridTextColumn Header="هدف"           Binding="{Binding Purpose, Converter={StaticResource EnumDescriptionConverter}}"   Width="150"/>
                        <DataGridTextColumn Header="وضعیت"         Binding="{Binding Status,  Converter={StaticResource EnumDescriptionConverter}}"   Width="90"/>
                        <DataGridTextColumn Header="صدور"          Binding="{Binding IssuedAtUtc,  Converter={StaticResource JalaliDateTimeConverter}}" Width="150"/>
                        <DataGridTextColumn Header="انقضا"         Binding="{Binding ExpiresAtUtc, Converter={StaticResource JalaliDateTimeConverter}}" Width="150"/>
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
