<UserControl x:Class="MilOps.Presentation.Views.TokensView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Loaded="TokensView_Loaded">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Generation form -->
        <Border Grid.Row="0" Background="White" BorderBrush="#FFE0E0E0" BorderThickness="1" Padding="12" Margin="0,0,0,12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.ColumnSpan="4" Text="Generate Authorization Token" FontWeight="Bold" Margin="0,0,0,8"/>

                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,8,4">
                    <TextBlock Text="First Name" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding FirstName}" Padding="4"/>
                </StackPanel>
                <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,8,4">
                    <TextBlock Text="Last Name" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding LastName}" Padding="4"/>
                </StackPanel>
                <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,0,8,4">
                    <TextBlock Text="National Code" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding NationalCode}" Padding="4"/>
                </StackPanel>
                <StackPanel Grid.Row="1" Grid.Column="3" Margin="0,0,0,4">
                    <TextBlock Text="Personnel Code" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding PersonnelCode}" Padding="4"/>
                </StackPanel>

                <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,8,4">
                    <TextBlock Text="Rank" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding Rank}" Padding="4"/>
                </StackPanel>
                <StackPanel Grid.Row="2" Grid.Column="1" Margin="0,0,8,4">
                    <TextBlock Text="Service Start" Style="{StaticResource FieldLabel}"/>
                    <DatePicker SelectedDate="{Binding ServiceStart}"/>
                </StackPanel>
                <StackPanel Grid.Row="2" Grid.Column="2" Margin="0,0,8,4">
                    <TextBlock Text="Service End" Style="{StaticResource FieldLabel}"/>
                    <DatePicker SelectedDate="{Binding ServiceEnd}"/>
                </StackPanel>
                <StackPanel Grid.Row="2" Grid.Column="3" Margin="0,0,0,4">
                    <TextBlock Text="Purpose" Style="{StaticResource FieldLabel}"/>
                    <ComboBox ItemsSource="{Binding Purposes}" SelectedItem="{Binding Purpose}" Padding="4"/>
                </StackPanel>

                <StackPanel Grid.Row="3" Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Bottom" Margin="0,8,8,0">
                    <TextBlock Text="Valid (days):" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding ValidDays}" Width="60" Padding="4"/>
                </StackPanel>

                <StackPanel Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                    <Button Content="🔐 Generate Token" Style="{StaticResource PrimaryButton}" Command="{Binding GenerateCommand}" IsEnabled="{Binding IsNotBusy}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Existing tokens -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                <TextBlock Text="Filter:" Style="{StaticResource FieldLabel}"/>
                <ComboBox ItemsSource="{Binding Statuses}" SelectedItem="{Binding StatusFilter}" Width="120" Padding="4"/>
                <Button Content="Refresh" Style="{StaticResource PrimaryButton}" Command="{Binding LoadCommand}" Margin="8,0,0,0"/>
                <Button Content="Revoke" Style="{StaticResource DangerButton}" Command="{Binding RevokeCommand}" Margin="8,0,0,0"/>
            </StackPanel>
            <Border Grid.Row="1" Background="White" BorderBrush="#FFE0E0E0" BorderThickness="1">
                <DataGrid ItemsSource="{Binding Items}" SelectedItem="{Binding Selected}" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Preview" Binding="{Binding Preview}" Width="120"/>
                        <DataGridTextColumn Header="Holder" Binding="{Binding LastName}" Width="120"/>
                        <DataGridTextColumn Header="Nat. Code" Binding="{Binding NationalCode}" Width="110"/>
                        <DataGridTextColumn Header="Purpose" Binding="{Binding Purpose}" Width="140"/>
                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="90"/>
                        <DataGridTextColumn Header="Issued (UTC)" Binding="{Binding IssuedAtUtc, StringFormat=u}" Width="150"/>
                        <DataGridTextColumn Header="Expires (UTC)" Binding="{Binding ExpiresAtUtc, StringFormat=u}" Width="150"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>
        <TextBlock Grid.Row="1" Text="{Binding ErrorMessage}" Foreground="{DynamicResource DangerBrush}" VerticalAlignment="Bottom"/>
    </Grid>
</UserControl>
