<UserControl x:Class="MilOps.Presentation.Views.AttendanceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:v="clr-namespace:MilOps.Presentation.Views"
             FlowDirection="RightToLeft"
             Loaded="AttendanceView_Loaded">
    <Border Margin="16" CornerRadius="12" ClipToBounds="True"
            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
        <DockPanel>

            <!-- Header -->
            <Border DockPanel.Dock="Top" Padding="22,18">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#0F5C4A" Offset="0"/>
                        <GradientStop Color="#16826A" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <DockPanel>
                    <Border DockPanel.Dock="Right" Width="52" Height="52" CornerRadius="26"
                            Background="#22FFFFFF" VerticalAlignment="Center">
                        <TextBlock Text="📝" FontSize="26" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center" Margin="0,0,16,0">
                        <TextBlock Text="آمار و حضور و غیاب سربازان" Foreground="White" FontSize="20" FontWeight="Bold"/>
                        <TextBlock Text="ثبت روزانه حضور، غیبت و تأخیر — همراه با تغییر بخش و گزارش کامل هر سرباز"
                                   Foreground="#A8E0D0" FontSize="12" Margin="0,4,0,0"/>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Toolbar -->
            <Border DockPanel.Dock="Top" Background="White" Padding="14,12"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="تاریخ:" Style="{StaticResource FieldLabel}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <v:JalaliDatePicker SelectedDate="{Binding Date}" Width="150" Margin="0,0,16,0"/>
                    <Button Content="⟳ بازخوانی" Style="{StaticResource SecondaryButton}"
                            Command="{Binding LoadCommand}" Margin="0,0,16,0"/>
                    <Button Content="✓ ذخیره همه" Style="{StaticResource AccentButton}"
                            Command="{Binding SaveAllCommand}"/>
                </StackPanel>
            </Border>

            <!-- Error -->
            <TextBlock DockPanel.Dock="Bottom" Text="{Binding ErrorMessage}"
                       Foreground="{DynamicResource DangerBrush}" Margin="14,6,14,0" TextWrapping="Wrap"
                       Visibility="{Binding ErrorMessage, Converter={StaticResource NullToCollapsedConverter}}"/>

            <!-- Column header row -->
            <Border DockPanel.Dock="Top" Background="#F0F4F8" Padding="10,8" Margin="14,10,14,4">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="180"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="کد پرسنلی" Style="{StaticResource FieldLabel}" FontSize="11"/>
                    <TextBlock Grid.Column="1" Text="نام" Style="{StaticResource FieldLabel}" FontSize="11"/>
                    <TextBlock Grid.Column="2" Text="نام خانوادگی" Style="{StaticResource FieldLabel}" FontSize="11"/>
                    <TextBlock Grid.Column="3" Text="یگان/بخش" Style="{StaticResource FieldLabel}" FontSize="11"/>
                    <TextBlock Grid.Column="4" Text="وضعیت" Style="{StaticResource FieldLabel}" FontSize="11"/>
                    <TextBlock Grid.Column="5" Text="توضیح" Style="{StaticResource FieldLabel}" FontSize="11"/>
                    <TextBlock Grid.Column="6" Text="عملیات" Style="{StaticResource FieldLabel}" FontSize="11" HorizontalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- Roster rows -->
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Rows}" Margin="14,0,14,14" x:Name="RowsControl">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="0,6">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="140"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="180"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0" Text="{Binding PersonnelCode}" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="{Binding FirstName}" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="{Binding LastName}" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="3" Text="{Binding DepartmentName}" VerticalAlignment="Center"/>

                                    <ComboBox Grid.Column="4" Margin="0,0,8,0"
                                              ItemsSource="{Binding DataContext.Statuses,
                                                  RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                              SelectedItem="{Binding Status}">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Converter={StaticResource EnumDescriptionConverter}}"/>
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>

                                    <TextBox Grid.Column="5" Margin="0,0,8,0"
                                             Text="{Binding Reason, UpdateSourceTrigger=PropertyChanged}"/>

                                    <StackPanel Grid.Column="6" Orientation="Horizontal" HorizontalAlignment="Center">
                                        <Button Content="تغییر بخش" Style="{StaticResource SecondaryButton}"
                                                MinHeight="0" Height="28" Padding="8,0" FontSize="11"
                                                CommandParameter="{Binding}"
                                                Command="{Binding DataContext.ChangeDepartmentCommand,
                                                    RelativeSource={RelativeSource AncestorType=ItemsControl}}"/>
                                        <Button Content="گزارش" Style="{StaticResource SecondaryButton}"
                                                MinHeight="0" Height="28" Padding="8,0" FontSize="11" Margin="6,0,0,0"
                                                CommandParameter="{Binding}"
                                                Command="{Binding DataContext.ExportSoldierReportCommand,
                                                    RelativeSource={RelativeSource AncestorType=ItemsControl}}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

        </DockPanel>
    </Border>
</UserControl>
