<UserControl x:Class="MilOps.Presentation.Views.JalaliDatePicker"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinHeight="36" FlowDirection="RightToLeft">
    <UserControl.Resources>

        <!-- Day button — states driven by Tag: null | "today" | "selected" | "selected-today" -->
        <Style x:Key="CalDayBtn" TargetType="Button">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Width"          Value="36"/>
            <Setter Property="Height"         Value="36"/>
            <Setter Property="Padding"        Value="0"/>
            <Setter Property="Cursor"         Value="Hand"/>
            <Setter Property="FontSize"       Value="12.5"/>
            <Setter Property="FontWeight"     Value="Normal"/>
            <Setter Property="FontFamily"     Value="{DynamicResource AppFont}"/>
            <Setter Property="Background"     Value="Transparent"/>
            <Setter Property="Foreground"     Value="{DynamicResource TextBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="BorderBrush"    Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="18">
                            <TextBlock x:Name="txt"
                                       Text="{TemplateBinding Content}"
                                       Foreground="{TemplateBinding Foreground}"
                                       FontFamily="{TemplateBinding FontFamily}"
                                       FontSize="{TemplateBinding FontSize}"
                                       FontWeight="{TemplateBinding FontWeight}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <!-- Default hover -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#EBF4FF"/>
                            </Trigger>
                            <!-- Today: ring + light tint -->
                            <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}" Value="today">
                                <Setter TargetName="bd" Property="Background"     Value="#EBF0FA"/>
                                <Setter TargetName="bd" Property="BorderBrush"    Value="#1F4E79"/>
                                <Setter TargetName="bd" Property="BorderThickness" Value="2"/>
                                <Setter TargetName="txt" Property="Foreground"    Value="#1F4E79"/>
                                <Setter TargetName="txt" Property="FontWeight"    Value="Bold"/>
                            </DataTrigger>
                            <!-- Selected: filled primary -->
                            <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}" Value="selected">
                                <Setter TargetName="bd" Property="Background"    Value="#1F4E79"/>
                                <Setter TargetName="txt" Property="Foreground"   Value="White"/>
                                <Setter TargetName="txt" Property="FontWeight"   Value="SemiBold"/>
                            </DataTrigger>
                            <!-- Selected + Today: darker fill + gold ring -->
                            <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}" Value="selected-today">
                                <Setter TargetName="bd" Property="Background"     Value="#163A5C"/>
                                <Setter TargetName="bd" Property="BorderBrush"    Value="#C9A227"/>
                                <Setter TargetName="bd" Property="BorderThickness" Value="2"/>
                                <Setter TargetName="txt" Property="Foreground"    Value="White"/>
                                <Setter TargetName="txt" Property="FontWeight"    Value="Bold"/>
                            </DataTrigger>
                            <!-- Hover on Today: slightly deeper ring tint -->
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource TemplatedParent}}" Value="True"/>
                                    <Condition Binding="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}" Value="today"/>
                                </MultiDataTrigger.Conditions>
                                <Setter TargetName="bd" Property="Background" Value="#D0E4F7"/>
                            </MultiDataTrigger>
                            <!-- Hover on Selected: keep filled, slightly lighter -->
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource TemplatedParent}}" Value="True"/>
                                    <Condition Binding="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}" Value="selected"/>
                                </MultiDataTrigger.Conditions>
                                <Setter TargetName="bd" Property="Background" Value="#163A5C"/>
                            </MultiDataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Circular navigation arrow button -->
        <Style x:Key="CalNavBtn" TargetType="Button">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Width"      Value="32"/>
            <Setter Property="Height"     Value="32"/>
            <Setter Property="Padding"    Value="0"/>
            <Setter Property="Cursor"     Value="Hand"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="16">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#EEF2F8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#DDE5F0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <Grid>
        <!-- ── Input field ──────────────────────────────────────── -->
        <Border x:Name="OuterBorder"
                CornerRadius="8"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                Background="White"
                ClipToBounds="True">
            <Grid>
                <Grid.ColumnDefinitions>
                    <!-- Col 0: RTL = physical right = text -->
                    <ColumnDefinition Width="*"/>
                    <!-- Col 1: RTL = physical left = calendar button -->
                    <ColumnDefinition Width="38"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="DateTextBox" Grid.Column="0"
                         FlowDirection="LeftToRight"
                         BorderThickness="0" Padding="10,0"
                         Background="Transparent"
                         VerticalContentAlignment="Center"
                         LostFocus="DateTextBox_LostFocus"
                         KeyDown="DateTextBox_KeyDown"/>

                <Border Grid.Column="1"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1,0,0,0">
                    <Button x:Name="CalBtn"
                            Cursor="Hand" Click="CalBtn_Click"
                            ToolTip="انتخاب تاریخ شمسی">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="iconBd" Background="Transparent">
                                    <!-- Calendar icon (SVG path) -->
                                    <Path HorizontalAlignment="Center" VerticalAlignment="Center"
                                          Width="16" Height="14" Stretch="Uniform"
                                          Fill="Transparent"
                                          Stroke="{DynamicResource MutedBrush}"
                                          StrokeThickness="1.3"
                                          StrokeLineJoin="Round"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          Data="M 1,3 L 1,13 L 13,13 L 13,3 Z
                                                M 1,6 L 13,6
                                                M 4,1 L 4,4
                                                M 10,1 L 10,4
                                                M 4,8.5 L 4,8.5
                                                M 7,8.5 L 7,8.5
                                                M 10,8.5 L 10,8.5
                                                M 4,11 L 4,11
                                                M 7,11 L 7,11"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="iconBd" Property="Background" Value="#F0F4F8"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="iconBd" Property="Background" Value="#E4EBF4"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Border>
            </Grid>
        </Border>

        <!-- ── Calendar popup ────────────────────────────────────── -->
        <Popup x:Name="CalendarPopup"
               AllowsTransparency="True"
               IsOpen="False"
               StaysOpen="False"
               PlacementTarget="{Binding ElementName=OuterBorder}"
               Placement="Bottom"
               VerticalOffset="6"
               PopupAnimation="Fade">

            <Border Background="White"
                    CornerRadius="16"
                    BorderThickness="1"
                    BorderBrush="#E4ECF4"
                    Padding="16,14">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" Opacity="0.13"
                                      BlurRadius="32" ShadowDepth="8" Direction="270"/>
                </Border.Effect>

                <StackPanel Width="280" FlowDirection="RightToLeft">

                    <!-- Month / year navigation (LTR so arrows don't flip) -->
                    <Grid FlowDirection="LeftToRight" Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="36"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="36"/>
                        </Grid.ColumnDefinitions>

                        <!-- Previous month (physical left) -->
                        <Button Grid.Column="0" x:Name="PrevBtn"
                                Style="{StaticResource CalNavBtn}"
                                Click="PrevMonth_Click">
                            <Path Data="M 8,3 L 4,7 L 8,11"
                                  Stroke="{DynamicResource MutedBrush}" StrokeThickness="2"
                                  StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                  Fill="Transparent" Width="12" Height="8" Stretch="Uniform"/>
                        </Button>

                        <TextBlock x:Name="MonthYearLabel" Grid.Column="1"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   FontWeight="SemiBold" FontSize="14.5"
                                   Foreground="{DynamicResource PrimaryBrush}"/>

                        <!-- Next month (physical right) -->
                        <Button Grid.Column="2" x:Name="NextBtn"
                                Style="{StaticResource CalNavBtn}"
                                Click="NextMonth_Click">
                            <Path Data="M 4,3 L 8,7 L 4,11"
                                  Stroke="{DynamicResource MutedBrush}" StrokeThickness="2"
                                  StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                  Fill="Transparent" Width="12" Height="8" Stretch="Uniform"/>
                        </Button>
                    </Grid>

                    <!-- Weekday headers -->
                    <Border CornerRadius="8" Padding="0,7" Margin="0,0,0,4">
                        <Border.Background>
                            <SolidColorBrush Color="#F3F6FA"/>
                        </Border.Background>
                        <UniformGrid Columns="7">
                            <TextBlock Text="ش" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource MutedBrush}" HorizontalAlignment="Center"/>
                            <TextBlock Text="ی" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource MutedBrush}" HorizontalAlignment="Center"/>
                            <TextBlock Text="د" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource MutedBrush}" HorizontalAlignment="Center"/>
                            <TextBlock Text="س" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource MutedBrush}" HorizontalAlignment="Center"/>
                            <TextBlock Text="چ" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource MutedBrush}" HorizontalAlignment="Center"/>
                            <TextBlock Text="پ" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource MutedBrush}" HorizontalAlignment="Center"/>
                            <TextBlock Text="ج" FontSize="11" FontWeight="SemiBold" Foreground="#C0392B" HorizontalAlignment="Center"/>
                        </UniformGrid>
                    </Border>

                    <!-- Day buttons (populated in code-behind via Tag states) -->
                    <UniformGrid x:Name="DaysGrid" Columns="7" Margin="0,4,0,0"/>

                    <!-- Footer divider + Today button -->
                    <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0"
                            Margin="0,14,0,0" Padding="0,12,0,0">
                        <Button Content="برو به امروز"
                                HorizontalAlignment="Center"
                                Height="30" Padding="18,0"
                                FontSize="12" Cursor="Hand"
                                Click="Today_Click"
                                Style="{DynamicResource SecondaryButton}"/>
                    </Border>

                </StackPanel>
            </Border>
        </Popup>
    </Grid>
</UserControl>
