<Window x:Class="MilOps.Presentation.Views.ChangeDepartmentDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="تغییر بخش"
        Width="380" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="White"
        FlowDirection="RightToLeft">
    <StackPanel>

        <!-- Header -->
        <Border Padding="20,16">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#1C3558" Offset="0"/>
                    <GradientStop Color="#22487A" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <StackPanel>
                <TextBlock Text="تغییر بخش سرباز" Foreground="White" FontSize="14" FontWeight="SemiBold"/>
                <TextBlock Text="{Binding SoldierDisplayName}" Foreground="#C8D8EA" FontSize="12" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- Fields -->
        <StackPanel Margin="20,18,20,0">
            <TextBlock Text="بخش فعلی" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
            <TextBlock Text="{Binding CurrentDepartment}" Foreground="{DynamicResource MutedBrush}" Margin="0,0,0,14"/>

            <TextBlock Text="بخش جدید" Style="{StaticResource FieldLabel}" Margin="0,0,0,5"/>
            <TextBox Text="{Binding NewDepartment, UpdateSourceTrigger=PropertyChanged}" Padding="10,9"/>
            <TextBlock Style="{StaticResource FieldError}" Text="{Binding FieldErrors[NewDepartmentName]}"/>

            <TextBlock Text="{Binding ErrorMessage}" Foreground="{DynamicResource DangerBrush}"
                       TextWrapping="Wrap" Margin="0,8,0,0"
                       Visibility="{Binding ErrorMessage, Converter={StaticResource NullToCollapsedConverter}}"/>
        </StackPanel>

        <!-- Actions -->
        <Grid Margin="20,16,20,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Content="ذخیره" Style="{StaticResource PrimaryButton}"
                    MinHeight="38" IsDefault="True" IsEnabled="{Binding IsNotBusy}"
                    Command="{Binding SaveCommand}"/>
            <Button Grid.Column="2" Content="انصراف" Style="{StaticResource SecondaryButton}"
                    MinHeight="38" IsCancel="True" Command="{Binding CancelCommand}"/>
        </Grid>

    </StackPanel>
</Window>
