<UserControl x:Class="MilOps.Presentation.Views.UsersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FlowDirection="RightToLeft"
             Loaded="UsersView_Loaded">
    <Border Margin="16" CornerRadius="12" ClipToBounds="True"
            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
        <DockPanel>

            <!-- Header -->
            <Border DockPanel.Dock="Top" Padding="22,18">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#212F3D" Offset="0"/>
                        <GradientStop Color="#2C3E50" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <DockPanel>
                    <Border DockPanel.Dock="Right" Width="52" Height="52" CornerRadius="26"
                            Background="#22FFFFFF" VerticalAlignment="Center">
                        <TextBlock Text="⚙" FontSize="26" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center" Margin="0,0,16,0">
                        <TextBlock Text="مدیریت کاربران" Foreground="White" FontSize="20" FontWeight="Bold"/>
                        <TextBlock Text="حساب‌های کاربری و سطوح دسترسی" Foreground="#A0B4C8" FontSize="12" Margin="0,4,0,0"/>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Add user form -->
            <Border DockPanel.Dock="Top" Background="White" Padding="16,14"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                        <TextBlock Text="نام کامل" Style="{StaticResource FieldLabel}" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding NewFullName, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Style="{StaticResource FieldError}" Text="{Binding FieldErrors[FullName]}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="0,0,10,0">
                        <TextBlock Text="نام کاربری" Style="{StaticResource FieldLabel}" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding NewUsername, UpdateSourceTrigger=PropertyChanged}" FlowDirection="LeftToRight"/>
                        <TextBlock Style="{StaticResource FieldError}" Text="{Binding FieldErrors[Username]}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Margin="0,0,10,0">
                        <TextBlock Text="گذرواژه" Style="{StaticResource FieldLabel}" Margin="0,0,0,5"/>
                        <PasswordBox x:Name="NewPasswordBox" PasswordChanged="NewPasswordBox_PasswordChanged"
                                     FlowDirection="LeftToRight"/>
                        <!-- Shown before a failed attempt, not just after — the
                             requirement used to only surface via FieldErrors. -->
                        <TextBlock Text="{Binding PasswordHint}" Foreground="{DynamicResource MutedBrush}"
                                   FontSize="11" Margin="0,3,0,0"
                                   Visibility="{Binding FieldErrors[Password], Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=inverse}"/>
                        <TextBlock Style="{StaticResource FieldError}" Text="{Binding FieldErrors[Password]}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="3" Margin="0,0,10,0">
                        <TextBlock Text="نقش" Style="{StaticResource FieldLabel}" Margin="0,0,0,5"/>
                        <ComboBox ItemsSource="{Binding Roles}" SelectedItem="{Binding NewRole}" Width="120"/>
                    </StackPanel>
                    <Button Grid.Column="4" Content="＋ افزودن" Style="{StaticResource AccentButton}"
                            Command="{Binding CreateCommand}" IsEnabled="{Binding IsNotBusy}"
                            VerticalAlignment="Top" Margin="0,21,0,0"/>
                </Grid>
            </Border>

            <!-- Action toolbar -->
            <Border DockPanel.Dock="Top" Background="#F8FAFC" Padding="14,10"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                <StackPanel Orientation="Horizontal">
                    <Button Content="🔐 بازنشانی گذرواژه" Style="{StaticResource PrimaryButton}"
                            Command="{Binding ChangePasswordCommand}" Margin="0,0,8,0"
                            ToolTip="ابتدا یک کاربر را از فهرست انتخاب کنید"/>
                    <Button Content="✕ غیرفعال‌سازی" Style="{StaticResource DangerButton}"
                            Command="{Binding DeactivateCommand}" Margin="0,0,8,0"
                            ToolTip="ابتدا یک کاربر را از فهرست انتخاب کنید"/>
                    <Button Content="بازخوانی" Style="{StaticResource SecondaryButton}"
                            Command="{Binding LoadCommand}" Margin="0,0,16,0"/>
                    <TextBlock Text="تغییر نقش به:" Style="{StaticResource FieldLabel}"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <ComboBox ItemsSource="{Binding Roles}" SelectedItem="{Binding RoleForChange}"
                              Width="120" Margin="0,0,4,0"/>
                    <Button Content="🎖 اعمال نقش" Style="{StaticResource SecondaryButton}"
                            Command="{Binding ChangeRoleCommand}"
                            ToolTip="تغییر نقش کاربر انتخاب‌شده"/>
                </StackPanel>
            </Border>

            <!-- Error -->
            <TextBlock DockPanel.Dock="Bottom" Text="{Binding ErrorMessage}"
                       Foreground="{DynamicResource DangerBrush}" Margin="14,6,14,0" TextWrapping="Wrap"
                       Visibility="{Binding ErrorMessage, Converter={StaticResource NullToCollapsedConverter}}"/>

            <!-- Data -->
            <DataGrid FlowDirection="RightToLeft"
                      ItemsSource="{Binding Items}" SelectedItem="{Binding Selected}"
                      AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="شناسه"     Binding="{Binding Id}"       Width="60"/>
                    <DataGridTextColumn Header="نام کاربری" Binding="{Binding Username}" Width="160"/>
                    <DataGridTextColumn Header="نام کامل"   Binding="{Binding FullName}" Width="200"/>
                    <DataGridTextColumn Header="نقش"        Binding="{Binding Role, Converter={StaticResource EnumDescriptionConverter}}"     Width="130"/>
                    <!-- Single status column: two separate checkmarks (فعال + فعال‌سازی)
                         used to read as "already usable" for a brand-new,
                         not-yet-activated account. -->
                    <DataGridTextColumn Header="وضعیت" Binding="{Binding StatusText}" Width="140">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding StatusText}" Value="غیرفعال">
                                        <Setter Property="Foreground" Value="{DynamicResource DangerBrush}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding StatusText}" Value="در انتظار فعال‌سازی">
                                        <Setter Property="Foreground" Value="#C9A227"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding StatusText}" Value="فعال">
                                        <Setter Property="Foreground" Value="#1E8449"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>

        </DockPanel>
    </Border>
</UserControl>
