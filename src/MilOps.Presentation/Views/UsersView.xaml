<UserControl x:Class="MilOps.Presentation.Views.UsersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Loaded="UsersView_Loaded">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" BorderBrush="#FFE0E0E0" BorderThickness="1" Padding="12" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Full Name:" Style="{StaticResource FieldLabel}"/>
                <TextBox Text="{Binding NewFullName, UpdateSourceTrigger=PropertyChanged}" Width="120" Padding="4" Margin="0,0,8,0"/>
                <TextBlock Text="Username:" Style="{StaticResource FieldLabel}"/>
                <TextBox Text="{Binding NewUsername, UpdateSourceTrigger=PropertyChanged}" Width="120" Padding="4" Margin="0,0,8,0"/>
                <TextBlock Text="Password:" Style="{StaticResource FieldLabel}"/>
                <TextBox Text="{Binding NewPassword, UpdateSourceTrigger=PropertyChanged}" Width="120" Padding="4" Margin="0,0,8,0"/>
                <TextBlock Text="Role:" Style="{StaticResource FieldLabel}"/>
                <ComboBox ItemsSource="{Binding Roles}" SelectedItem="{Binding NewRole}" Width="110" Padding="4" Margin="0,0,8,0"/>
                <Button Content="+ Create" Style="{StaticResource PrimaryButton}" Command="{Binding CreateCommand}"/>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
            <Button Content="Change Password" Style="{StaticResource PrimaryButton}" Command="{Binding ChangePasswordCommand}" Margin="0,0,8,0"/>
            <Button Content="Deactivate" Style="{StaticResource DangerButton}" Command="{Binding DeactivateCommand}" Margin="0,0,8,0"/>
            <Button Content="Refresh" Style="{StaticResource PrimaryButton}" Command="{Binding LoadCommand}"/>
        </StackPanel>

        <Border Grid.Row="2" Background="White" BorderBrush="#FFE0E0E0" BorderThickness="1">
            <DataGrid ItemsSource="{Binding Items}" SelectedItem="{Binding Selected}" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                    <DataGridTextColumn Header="Username" Binding="{Binding Username}" Width="150"/>
                    <DataGridTextColumn Header="Full Name" Binding="{Binding FullName}" Width="180"/>
                    <DataGridTextColumn Header="Role" Binding="{Binding Role}" Width="120"/>
                    <DataGridCheckBoxColumn Header="Active" Binding="{Binding IsActive}" Width="70"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
        <TextBlock Grid.Row="2" Text="{Binding ErrorMessage}" Foreground="{DynamicResource DangerBrush}" VerticalAlignment="Bottom"/>
    </Grid>
</UserControl>
