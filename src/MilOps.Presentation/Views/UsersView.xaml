<UserControl x:Class="MilOps.Presentation.Views.UsersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Loaded="UsersView_Loaded">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource Card}" Padding="12" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="نام کامل:" Style="{StaticResource FieldLabel}"/>
                <TextBox Text="{Binding NewFullName, UpdateSourceTrigger=PropertyChanged}" Width="120" Padding="4" Margin="0,0,8,0"/>
                <TextBlock Text="نام کاربری:" Style="{StaticResource FieldLabel}"/>
                <TextBox Text="{Binding NewUsername, UpdateSourceTrigger=PropertyChanged}" Width="120" Padding="4" Margin="0,0,8,0"/>
                <TextBlock Text="گذرواژه:" Style="{StaticResource FieldLabel}"/>
                <TextBox Text="{Binding NewPassword, UpdateSourceTrigger=PropertyChanged}" Width="120" Padding="4" Margin="0,0,8,0"/>
                <TextBlock Text="نقش:" Style="{StaticResource FieldLabel}"/>
                <ComboBox ItemsSource="{Binding Roles}" SelectedItem="{Binding NewRole}" Width="110" Padding="4" Margin="0,0,8,0"/>
                <Button Content="افزودن" Style="{StaticResource PrimaryButton}" Command="{Binding CreateCommand}"/>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
            <Button Content="بازنشانی گذرواژه" Style="{StaticResource PrimaryButton}" Command="{Binding ChangePasswordCommand}" Margin="0,0,8,0"/>
            <Button Content="غیرفعال‌سازی" Style="{StaticResource DangerButton}" Command="{Binding DeactivateCommand}" Margin="0,0,8,0"/>
            <Button Content="بازخوانی" Style="{StaticResource SecondaryButton}" Command="{Binding LoadCommand}"/>
        </StackPanel>

        <Border Grid.Row="2" Style="{StaticResource Card}">
            <DataGrid ItemsSource="{Binding Items}" SelectedItem="{Binding Selected}" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="شناسه" Binding="{Binding Id}" Width="50"/>
                    <DataGridTextColumn Header="نام کاربری" Binding="{Binding Username}" Width="150"/>
                    <DataGridTextColumn Header="نام کامل" Binding="{Binding FullName}" Width="180"/>
                    <DataGridTextColumn Header="نقش" Binding="{Binding Role}" Width="120"/>
                    <DataGridCheckBoxColumn Header="فعال" Binding="{Binding IsActive}" Width="70"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
        <TextBlock Grid.Row="2" Text="{Binding ErrorMessage}" Foreground="{DynamicResource DangerBrush}" VerticalAlignment="Bottom"/>
    </Grid>
</UserControl>
