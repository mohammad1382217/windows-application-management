<Application x:Class="MilOps.Presentation.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:MilOps.Presentation.Converters">
    <!-- StartupUri is intentionally omitted: App.xaml.cs resolves the LoginWindow
         from DI so its LoginViewModel dependency is injected. -->
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Themes/Theme.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Value converters shared across all views. -->
            <conv:NullToCollapsedConverter x:Key="NullToCollapsedConverter" />
            <conv:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
            <conv:BoolToVisibilityConverter x:Key="BoolToVisConverter" />
            <conv:InverseBoolConverter x:Key="InverseBoolConverter" />
            <conv:JalaliDateConverter x:Key="JalaliDateConverter" />
            <conv:JalaliDateTimeConverter x:Key="JalaliDateTimeConverter" />
            <conv:PersianDigitsConverter x:Key="PersianDigitsConverter" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
