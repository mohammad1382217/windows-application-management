<?xml version="1.0" encoding="utf-8"?>
<!--
  Self-contained, single-file publish profile for the MilOps WPF app.

  Result: a single MilOps.exe (~150 MB) under publish/ that contains the .NET 10
  Desktop Runtime, all managed assemblies, and the native e_sqlcipher/e_sqlite3
  DLLs (which self-extract to a temp dir at first launch). No .NET runtime needs
  to be pre-installed on the target machine.

  This is the artifact the WiX installer packages.
-->
<Project>
  <PropertyGroup>
    <Configuration>Release</Configuration>
    <Platform>Any CPU</Platform>
    <PublishDir>bin\Release\publish\</PublishDir>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <SelfContained>true</SelfContained>
    <PublishSingleFile>true</PublishSingleFile>
    <!-- Bundle native DLLs (e_sqlcipher.dll) INTO the single exe; extract at runtime. -->
    <IncludeNativeLibrariesForSelfExtract>true</IncludeNativeLibrariesForSelfExtract>
    <!-- Include PDBs inside the bundle for smaller file set; disable for leaner build. -->
    <DebugType>embedded</DebugType>
    <!-- Optional: faster startup with R2R, slightly larger exe. -->
    <PublishReadyToRun>false</PublishReadyToRun>
    <DeleteExistingFiles>true</DeleteExistingFiles>
    <TargetFramework>net10.0-windows</TargetFramework>
  </PropertyGroup>
</Project>
